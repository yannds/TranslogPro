# ============================================================
# TRANSLOG PRO — Variables d'Environnement
# ============================================================
# RÈGLE ABSOLUE : En production, SEULE la variable VAULT_ADDR
# est autorisée. Toutes les autres viennent de Vault via ISecretService.
# Ce fichier est uniquement pour le développement local.
# ============================================================

# ─── OBLIGATOIRE (dev et prod) ───────────────────────────────
VAULT_ADDR=http://localhost:8200

# ─── DÉVELOPPEMENT UNIQUEMENT ────────────────────────────────
NODE_ENV=development

# Vault dev token (ne jamais utiliser en production)
VAULT_TOKEN=dev-root-token

# Database directe (sans Vault, pour prisma migrate en dev)
DATABASE_URL=postgresql://app_user:app_password@localhost:5432/translog?schema=public
DATABASE_URL_POOLED=postgresql://app_user:app_password@localhost:5433/translog?schema=public

# Redis (pour developpement local sans Vault)
REDIS_URL=redis://:redis_password@localhost:6379

# MinIO (pour developpement local sans Vault)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false

# App
PORT=3000
WS_PORT=3001

# Logging
LOG_LEVEL=debug

# ─── Multi-tenant routing (Phase 1) ──────────────────────────────
# Domaine plateforme — utilisé par HostConfigService (backend) pour résoudre
# les sous-domaines tenants en tenantId. MIROIR de scripts/dev.config.sh.
# Dev  : translog.test   (RFC 2606, non routable — safe)
# Prod : translogpro.com
PLATFORM_BASE_DOMAIN=translog.test

# Alias recommandé (Phase 2+) : PUBLIC_BASE_DOMAIN prend le pas sur
# PLATFORM_BASE_DOMAIN dans AppConfigService. Définir les deux en dev pour
# éviter les divergences ; en prod n'exposer que PUBLIC_BASE_DOMAIN.
PUBLIC_BASE_DOMAIN=translog.test

# Sous-domaine réservé à la zone super-admin plateforme (Phase 2).
# admin.$PLATFORM_BASE_DOMAIN → PLATFORM_TENANT_ID.
ADMIN_SUBDOMAIN=admin

# ─── URLs publiques (override optionnel, sinon dérivées du base domain) ──
# Si non défini, AppConfigService calcule :
#   PUBLIC_APP_URL      = https://admin.<PUBLIC_BASE_DOMAIN>
#   PUBLIC_PORTAL_URL   = https://portail.<PUBLIC_BASE_DOMAIN>
#   PUBLIC_TRACKING_URL = https://track.<PUBLIC_BASE_DOMAIN>
#   ERROR_DOCS_BASE_URL = https://<PUBLIC_BASE_DOMAIN>/errors
# En prod, définir les overrides seulement si le schéma diffère de la convention.
# PUBLIC_APP_URL=https://admin.translogpro.com
# PUBLIC_PORTAL_URL=https://portail.translogpro.com
PUBLIC_TRACKING_URL=https://track.translogpro.io
ERROR_DOCS_BASE_URL=https://translogpro.io/errors

# ─── Contacts publics ────────────────────────────────────────────
# Email de support affiché dans les emails transactionnels, erreurs UI, etc.
# Fallback : support@<PUBLIC_BASE_DOMAIN>.
SUPPORT_EMAIL=support@translogpro.com

# ─── Observabilité (Lot 1) ────────────────────────────────────────
# Mot de passe admin Grafana sur https://grafana.translog.dsyann.info
# En prod, généré aléatoirement par 04-deploy.sh si absent et persisté
# dans .env.prod. En dev, mot de passe simple OK (non exposé publiquement).
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin_dev_only_change_me
