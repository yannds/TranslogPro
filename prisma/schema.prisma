// ============================================================
// TransLog Pro — Prisma Schema v3.0 (Post-PRD-ADD Integration)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// SECTION 1 : CORE & IDENTITY
// ─────────────────────────────────────────────────────────────

model Tenant {
  id              String  @id @default(uuid())
  name            String
  slug            String  @unique
  settings        Json    @default("{}")
  isActive        Boolean @default(true)
  provisionStatus String  @default("PENDING")
  // PENDING | PROVISIONING | ACTIVE | SUSPENDED

  // ── Localisation & régional ─────────────────────────────────────────────────
  // country    : ISO 3166-1 alpha-2 (ex: "CG"). Drive les villes, TZ, devise par défaut.
  // language   : ISO 639-1 — pilote l'affichage frontend via I18nProvider
  // timezone   : IANA TZ (ex: "Africa/Brazzaville")
  // currency   : ISO 4217 (ex: "XAF")
  // dateFormat : format d'affichage des dates
  country    String @default("CG")
  city       String @default("")
  language   String @default("fr")
  timezone   String @default("Africa/Brazzaville")
  currency   String @default("XAF")
  dateFormat String @default("DD/MM/YYYY")

  // ── Informations société ──────────────────────────────────────────────────
  // Utilisées sur les documents officiels (billets, factures, manifestes).
  // taxId : identifiant fiscal/registre commerce (RCCM, NIF, TIN selon le pays)
  rccm        String?
  phoneNumber String?
  email       String?
  website     String?
  address     String?
  taxId       String?

  // ── SaaS Plan / Lifecycle (gérés par le tenant plateforme) ──────────────
  // planId et subscription sont nullable — un tenant peut exister sans plan
  // souscrit (ex: tenant plateforme lui-même, tenants créés avant facturation).
  planId      String?
  activatedAt DateTime?
  suspendedAt DateTime?

  // ── Onboarding wizard (Phase 3) ────────────────────────────────────────
  // businessActivity      : TICKETING | PARCELS | MIXED — défini au signup public,
  //                         pilote l'étape 4 du wizard (trajet vs tarif colis).
  // onboardingCompletedAt : timestamp de fin du wizard. null = toujours rediriger
  //                         l'admin vers /onboarding au login (reprise auto).
  // activationEmailsSent  : dict { day1: ISO-date, day3: ISO-date, day7: ISO-date }
  //                         pour idempotence du cron drip — un tenant reçoit
  //                         AU MAX 3 emails d'activation, jamais doublon.
  businessActivity      String?
  onboardingCompletedAt DateTime?
  activationEmailsSent  Json      @default("{}")

  // Registres fiscaux configurables par pays — affiché sur les documents
  // Format : [{ label: "NIU", value: "CG-NIU-2024-00142" }, { label: "RCCM", value: "..." }]
  // Chaque pays utilise ses propres identifiants (NIU Congo, NIF France, TIN USA…)
  fiscalRegistries Json @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  agencies         Agency[]
  modules          InstalledModule[]
  routes           Route[]
  trips            Trip[]
  workflowConfigs  WorkflowConfig[]
  pricingRules     PricingRules[]
  buses            Bus[]
  stations         Station[]
  parcels          Parcel[]
  config           TenantConfig?
  brand            TenantBrand?
  businessConfig   TenantBusinessConfig?
  portalConfig     TenantPortalConfig?
  pages            TenantPage[]
  posts            TenantPost[]
  busCostProfiles  BusCostProfile[]
  fuelLogs         FuelLog[]
  odometerReadings OdometerReading[]
  tariffGrids      TariffGrid[]
  promotions       Promotion[]
  invoices         Invoice[]
  platforms        Platform[]
  announcements    Announcement[]
  customers        Customer[]
  plan             Plan?                 @relation(fields: [planId], references: [id])
  subscription     PlatformSubscription?
  platformInvoices PlatformInvoice[]
  supportTickets   SupportTicket[]
  dailyActiveUsers DailyActiveUser[]
  healthScores     TenantHealthScore[]
  domains          TenantDomain[]
  accounts         Account[]

  // ── Paiements & Fiscalité (ADR-paiement) ────────────────────────────────────
  // Toutes ces relations sont créées lors du provisioning via des seeds idempotents.
  taxes                 TenantTax[]
  paymentConfig         TenantPaymentConfig?
  paymentIntents        PaymentIntent[]
  paymentProviderStates PaymentProviderState[]
  oauthProviderStates   OAuthProviderState[]

  // Manifest = document récapitulatif d'un trajet — workflow manifest-standard
  manifests Manifest[]

  @@map("tenants")
}

// ─────────────────────────────────────────────────────────────
// TenantDomain — routage host → tenant (isolation cookies par sous-domaine)
//
// Phase 1 : une ligne `{slug}.translogpro.com` auto-créée par tenant
//           (seed-idempotent dans prisma/seeds/tenant-domain.seed.ts).
// Phase 3 : ajout de lignes custom (`billets.sa-marque.com`) pour white-label
//           premium ; vérification CNAME + provisioning Caddy on-demand TLS.
//
// Résolu par TenantResolverService (core/tenancy) via Host header.
// Unicité globale de `hostname` : un hostname ne peut pointer que sur 1 tenant.
// ─────────────────────────────────────────────────────────────
model TenantDomain {
  id         String    @id @default(cuid())
  tenantId   String
  hostname   String    @unique // ex: "compagnie-a.translogpro.com", "billets.sa-marque.com"
  isPrimary  Boolean   @default(false) // hostname canonique du tenant (1 par tenant max)
  verifiedAt DateTime? // null tant que le CNAME n'est pas vérifié (Phase 3)
  certStatus String? // "ISSUED" | "PENDING" | "FAILED" — Phase 3 (Caddy)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, isPrimary])
  @@map("tenant_domains")
}

// Paramètres opérationnels par tenant — 1:1 avec Tenant.
// Chargés en cache (TTL 5min) pour ne pas pénaliser les affichages haute fréquence.
model TenantConfig {
  id       String @id @default(cuid())
  tenantId String @unique

  // ── Géo-sécurité ─────────────────────────────────────────────
  // Distance maximale (km) pour le score de corrélation GPS Safety
  proximityThresholdKm     Float @default(5.0)
  // Score minimum pour auto-vérifier une alerte (Safety + PublicReporter)
  autoVerifyScoreThreshold Float @default(0.9)
  // PublicReporter : distance (km) pour score=1.0 (linéaire jusqu'à 0)
  publicProximityKm        Float @default(0.5)

  // ── Affichage gare ────────────────────────────────────────────
  // Scope par défaut des écrans (station | city | tenant)
  displayScopeDefault String @default("station")
  // Nombre max de trajets retournés par l'endpoint display
  displayTakeLimit    Int    @default(20)
  // Horizon de prévision en heures (combien d'heures à venir afficher)
  displayHorizonHours Int    @default(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_configs")
}

// ── Marque Blanche (White Label) — configuration visuelle par tenant ──────────
// Chargée en cache Redis TTL 5 min pour ne pas pénaliser chaque requête.
model TenantBrand {
  id               String   @id @default(cuid())
  tenantId         String   @unique
  // Identité
  brandName        String
  logoUrl          String?
  faviconUrl       String?
  // Palette CSS (variables injectées dans le layout)
  primaryColor     String   @default("#2563eb")
  secondaryColor   String   @default("#1a3a5c")
  accentColor      String   @default("#f59e0b")
  textColor        String   @default("#111827")
  bgColor          String   @default("#ffffff")
  fontFamily       String   @default("Inter, sans-serif")
  // CSS additionnel (non-sanitisé en DB, sanitisé à l'injection)
  customCss        String?  @db.Text
  // SEO / support
  metaTitle        String?
  metaDescription  String?
  supportEmail     String?
  supportPhone     String?
  // Identité d'envoi email transactionnel (from/reply-to affichés au
  // destinataire). Si null, fallback sur la config plateforme au runtime.
  // Ces champs ne sont PAS des secrets — uniquement de l'affichage.
  emailFromName    String?
  emailFromAddress String?
  emailReplyTo     String?
  updatedAt        DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_brands")
}

// ── Constantes métier globales par tenant (ADR-24) ────────────────────────────
// Évite les magic numbers dans le code (365, 30, 0.05…).
// Créé automatiquement lors du provisioning tenant avec les valeurs par défaut.
model TenantBusinessConfig {
  id       String @id @default(cuid())
  tenantId String @unique

  // Proratisation annuelle → journalière
  daysPerYear            Int   @default(365)
  // Fallback trips/mois si BusCostProfile.avgTripsPerMonth absent
  defaultTripsPerMonth   Int   @default(30)
  // Seuil tag rentabilité ±% (PROFITABLE / BREAK_EVEN / DEFICIT)
  breakEvenThresholdPct  Float @default(0.05)
  // Commission agence sur revenus billets (fraction, ex: 0.03 = 3 %)
  agencyCommissionRate   Float @default(0.03)
  // Redevance gare routière par départ (en devise tenant)
  stationFeePerDeparture Float @default(0.0)

  // ── Fiscalité / TVA ─────────────────────────────────────────────────────────
  // En Afrique la TVA n'est pas systématique — certains transporteurs ne sont
  // pas assujettis ou appliquent un taux réduit. Si tvaEnabled = false les
  // prix affichés sont nets (= TTC), aucun calcul HT/TVA n'est effectué sur
  // les documents (factures, reçus).
  tvaEnabled Boolean @default(false)
  tvaRate    Float   @default(0.18) // fraction (0.18 = 18 %)

  // ── Option choix de siège (mode NUMBERED) ─────────────────────────────────
  // Montant facturé au passager s'il veut choisir son siège sur la seatmap.
  // 0 = option gratuite (la seatmap s'affiche sans surcoût).
  // Exprimé dans la devise du tenant (Tenant.currency).
  seatSelectionFee Float @default(0)

  // ── Politique d'annulation / remboursement ──────────────────────────────
  // Palier 1 : remboursement intégral si annulation ≥ cancellationFullRefundMinutes
  // avant le départ (ex: 1440 = 24 h).
  cancellationFullRefundMinutes    Int     @default(1440)
  // Palier 2 : remboursement partiel entre cancellationPartialRefundMinutes et
  // cancellationFullRefundMinutes (ex: 120 = 2 h).
  cancellationPartialRefundMinutes Int     @default(120)
  // Pourcentage du palier partiel (fraction, ex: 0.5 = 50 %).
  cancellationPartialRefundPct     Float   @default(0.5)
  // En dessous de cancellationPartialRefundMinutes → 0 % (non remboursable).
  // ── Seuils d'approbation remboursement ──────────────────────────────────
  // Montant max (en devise tenant) qu'un AGENCY_MANAGER peut approuver.
  // Au-delà → seul TENANT_ADMIN peut approuver.
  refundApprovalThreshold          Float   @default(50000)
  // Montant max auto-approuvé (skip approbation manuelle). 0 = désactivé.
  refundAutoApproveMax             Float   @default(0)
  // Si true, annulation de trajet (TRIP_CANCELLED) → remboursement 100 %
  // auto-approuvé quel que soit le montant.
  autoApproveTripCancelled         Boolean @default(true)

  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_business_configs")
}

// INVARIANT : tout tenant possède au moins une agence.
//   - Création : OnboardingService.onboard() provisionne l'agence par défaut
//     ("Agence principale" / "Main Agency") et l'admin y est rattaché automatiquement.
//   - Tenants existants : backfillDefaultAgencies() (prisma/seeds/iam.seed.ts).
//   - Suppression : AgencyService.remove() retourne 409 si c'est la dernière
//     agence du tenant.
// Cet invariant garantit que tout acteur ayant une permission en scope `.agency`
// dispose d'un agencyId valide (sans quoi PermissionGuard renverrait 403).
model Agency {
  id        String  @id @default(cuid())
  tenantId  String
  name      String
  stationId String?

  tenant                   Tenant                  @relation(fields: [tenantId], references: [id])
  station                  Station?                @relation(fields: [stationId], references: [id])
  users                    User[]
  cashRegisters            CashRegister[]
  staffAssignments         StaffAssignment[]
  staffAssignmentCoverages StaffAssignmentAgency[]
  buses                    Bus[]

  @@index([tenantId])
  @@map("agencies")
}

model User {
  id           String  @id @default(cuid())
  tenantId     String
  agencyId     String?
  // Email unique PAR TENANT (pas global) — un même humain peut avoir un compte
  // chez plusieurs tenants avec la même adresse. Voir @@unique([tenantId, email])
  // en fin de modèle. Pour l'isolation complète, l'auth résout le tenant depuis
  // le Host (sous-domaine) via TenantResolverService avant le lookup.
  email        String
  name         String?
  image        String?
  roleId       String?
  userType     String  @default("STAFF") // STAFF | CUSTOMER | ANONYMOUS
  isActive     Boolean @default(true) // désactivable sans suppression
  preferences  Json    @default("{}") // siège préféré, gares fav (clients)
  loyaltyScore Float   @default(0) // calculé — clients uniquement

  // ── MFA / TOTP ─────────────────────────────────────────────────
  // Infrastructure prête ; activation par tenant (plateforme, caissiers…)
  // via flag d'activation côté service. `mfaEnabled` reste à false tant
  // que l'utilisateur n'a pas finalisé le setup (scan QR + code valide).
  mfaEnabled     Boolean   @default(false)
  mfaSecret      String? // secret base32 TOTP (à chiffrer en prod — KMS)
  mfaBackupCodes String[]  @default([]) // codes de secours (hash bcrypt), single-use
  mfaVerifiedAt  DateTime? // moment d'activation effective

  // ── Activity tracking (pour DAU/MAU/adoption plateforme) ────────────────
  // Mis à jour par AuthService au login et périodiquement via middleware.
  lastLoginAt  DateTime?
  lastActiveAt DateTime?
  loginCount   Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant                 Tenant                  @relation(fields: [tenantId], references: [id])
  agency                 Agency?                 @relation(fields: [agencyId], references: [id])
  role                   Role?                   @relation(fields: [roleId], references: [id])
  sessions               Session[]
  mfaChallenges          MfaChallenge[]
  accounts               Account[]
  auditLogs              AuditLog[]
  checklists             Checklist[]
  staffProfile           Staff?
  notificationPreference NotificationPreference?
  notifications          Notification[]
  feedbacks              Feedback[]
  safetyAlerts           SafetyAlert[]
  customerProfile        Customer?               @relation("UserCustomerProfile")
  generatedManifests     Manifest[]              @relation("ManifestGenerator")
  signedManifests        Manifest[]              @relation("ManifestSigner")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, agencyId])
  @@index([tenantId, userType])
  @@map("users")
}

model Role {
  id          String           @id @default(uuid())
  tenantId    String
  name        String
  isSystem    Boolean          @default(false) // rôles système non supprimables
  permissions RolePermission[]
  users       User[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

// Permission: référence canonique (lookup/description uniquement)
model Permission {
  id          String @id @default(cuid())
  key         String @unique
  // FORMAT: {plane}.{module}.{action}.{scope}
  description String

  @@map("permissions")
}

// RolePermission: source de vérité runtime — stocke la string directement
// Le guard interroge cette table + Redis cache 60s (clé: iam:perm:{roleId}:{permission})
model RolePermission {
  id         String @id @default(cuid())
  roleId     String
  permission String // ex: "data.ticket.scan.agency"
  role       Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permission])
  @@index([roleId])
  @@map("role_permissions")
}

// ─────────────────────────────────────────────────────────────
// SECTION 2 : AUTH (Better Auth)
// ─────────────────────────────────────────────────────────────

model Session {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@map("sessions")
}

/// Challenge MFA — pré-session "en attente" entre étape 1 (password OK) et
/// étape 2 (code TOTP/backup vérifié). Délibérément SÉPARÉ de Session :
/// toute requête API authentifiée lit Session, donc un challenge non finalisé
/// ne doit JAMAIS pouvoir donner accès, même par erreur.
///
/// Cycle de vie :
///   1. AuthService.signIn (à venir) crée la ligne, pose le `token` dans un
///      cookie pré-session HttpOnly distinct (`translog_mfa_challenge`).
///   2. POST /auth/mfa/verify lit le cookie, vérifie le code, supprime la
///      ligne et crée une vraie Session.
///   3. Si attempts >= MAX (5) ou expiresAt dépassé → ligne supprimée, user
///      doit recommencer le sign-in.
///
/// Pas de FK CASCADE sur User volontairement : la ligne est éphémère (5min),
/// elle expire avant qu'un user puisse être supprimé.
model MfaChallenge {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  token     String   @unique // 256 bits — posé dans cookie pré-session
  ipAddress String?
  userAgent String?
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt]) // pour un éventuel cron de purge
  @@map("mfa_challenges")
}

model Account {
  id           String    @id @default(cuid())
  // tenantId dénormalisé depuis User : permet l'unicité `(tenantId, providerId, accountId)`
  // → même email "credential" peut exister dans plusieurs tenants (1 compte par tenant).
  // Source de vérité = User.tenantId ; synchronisé au create/upsert par AuthIdentityService.
  tenantId     String
  userId       String
  providerId   String // "credential" | "google" | ...
  accountId    String // email pour credential, userId OAuth pour providers externes
  password     String? // hash bcrypt (credential uniquement)
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?

  // ── Password reset (credential uniquement) ──────────────────────────
  // Le token clair n'est jamais stocké : seul son SHA-256 l'est, et la
  // ligne est effacée à la consommation (one-shot). TTL 30 min.
  passwordResetTokenHash String?   @unique
  passwordResetExpiresAt DateTime?

  // Forcer le changement de mot de passe au prochain login. Utilisé quand
  // un admin a défini lui-même un mot de passe pour un user (anti-pattern
  // atténué : l'admin le connaît, on force la rotation immédiate).
  forcePasswordChange Boolean @default(false)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, providerId, accountId])
  @@index([tenantId])
  @@index([passwordResetExpiresAt])
  @@map("accounts")
}

// ─────────────────────────────────────────────────────────────
// SECTION 3 : MODULES & CONFIGURATION
// ─────────────────────────────────────────────────────────────

model InstalledModule {
  id        String  @id @default(cuid())
  tenantId  String
  moduleKey String
  // YIELD_ENGINE | GARAGE_PRO | SAV_MODULE | SCHEDULER | QUOTA_MANAGER
  config    Json    @default("{}")
  isActive  Boolean @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, moduleKey])
  @@map("installed_modules")
}

model NotificationPreference {
  id       String  @id @default(cuid())
  userId   String  @unique
  tenantId String
  sms      Boolean @default(true)
  whatsapp Boolean @default(true)
  push     Boolean @default(true)
  email    Boolean @default(false)

  user User @relation(fields: [userId], references: [id])

  @@map("notification_preferences")
}

// Notification — historique de toutes les notifications envoyées.
// Alimenté par NotificationService après chaque envoi réel.
// Source de vérité pour l'onglet "Mes Notifications" dans les apps.
//
// status :
//   PENDING   → en attente d'envoi (file d'attente ISmsService)
//   SENT      → confirmé par le provider (Twilio SID reçu)
//   FAILED    → échec définitif (3 tentatives épuisées)
//   READ      → lu par l'utilisateur (IN_APP uniquement)
model Notification {
  id          String    @id @default(cuid())
  tenantId    String
  userId      String
  channel     String // SMS | WHATSAPP | PUSH | EMAIL | IN_APP
  templateId  String // identifiant du template (ex: "ticket.confirmed")
  title       String?
  body        String
  metadata    Json      @default("{}") // variables substituées, IDs liés
  status      String    @default("PENDING")
  externalRef String? // SID Twilio ou message_id WhatsApp
  failReason  String?
  attempts    Int       @default(0) // nombre de tentatives d'envoi
  sentAt      DateTime?
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, status])
  @@index([tenantId, createdAt])
  @@index([externalRef])
  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────
// SECTION 4 : WORKFLOW ENGINE
// ─────────────────────────────────────────────────────────────

model WorkflowConfig {
  id            String   @id @default(cuid())
  tenantId      String
  entityType    String
  // TICKET | PARCEL | TRIP | BUS | TRAVELER | SHIPMENT
  fromState     String
  action        String
  toState       String
  requiredPerm  String // ex: "data.ticket.scan.agency"
  guards        Json     @default("[]") // GuardDefinition[]
  sideEffects   Json     @default("[]") // SideEffectDefinition[]
  version       Int      @default(1)
  effectiveFrom DateTime @default(now())
  isActive      Boolean  @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, entityType, fromState, action, version])
  @@index([tenantId, entityType, isActive])
  @@map("workflow_configs")
}

model WorkflowTransition {
  id             String   @id @default(cuid())
  idempotencyKey String   @unique
  tenantId       String
  entityType     String
  entityId       String
  action         String
  fromState      String
  toState        String
  userId         String
  createdAt      DateTime @default(now())

  @@index([entityType, entityId])
  @@index([tenantId, createdAt])
  @@map("workflow_transitions")
}

// ─────────────────────────────────────────────────────────────
// SECTION 5 : AUDIT & EVENTS
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  userId        String?
  tenantId      String
  plane         String // control | data | http
  level         String // info | warn | critical
  action        String // ex: "data.ticket.board.agency"
  resource      String // ex: "Ticket:clx..."
  oldValue      Json?
  newValue      Json?
  ipAddress     String?
  securityLevel String? // INTERNAL | CONFIDENTIAL | RESTRICTED

  user User? @relation(fields: [userId], references: [id])

  // Partitionnement RANGE mensuel défini via migration SQL brute
  @@index([tenantId, createdAt])
  @@index([tenantId, action])
  @@index([resource])
  @@map("audit_logs")
}

model OutboxEvent {
  id            String    @id @default(cuid())
  tenantId      String
  eventType     String // ex: "ticket.boarded"
  aggregateType String // TICKET | TRIP | PARCEL | ...
  aggregateId   String
  payload       Json
  status        String    @default("PENDING")
  // PENDING | PROCESSING | DELIVERED | FAILED | DEAD
  attempts      Int       @default(0)
  lastError     String?
  scheduledAt   DateTime  @default(now())
  processedAt   DateTime?
  createdAt     DateTime  @default(now())

  @@index([status, scheduledAt])
  @@index([tenantId, eventType])
  @@map("outbox_events")
}

model DeadLetterEvent {
  id          String    @id @default(cuid())
  tenantId    String
  eventType   String
  aggregateId String
  payload     Json
  errorLog    Json      @default("[]")
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?

  @@index([tenantId, resolvedAt])
  @@map("dead_letter_events")
}

// ─────────────────────────────────────────────────────────────
// SECTION 5b : IMPERSONATION (Control Plane — Support JIT)
// ─────────────────────────────────────────────────────────────

// ImpersonationSession — enregistre chaque session JIT (PRD §IV.12).
//
// Cycle de vie :
//   ACTIVE → EXPIRED (TTL 15min atteint)
//   ACTIVE → REVOKED (actor révoque manuellement ou logout)
//
// actorTenantId est toujours PLATFORM_TENANT_ID (00000000-...).
// targetTenantId est l'ID du tenant client accédé.
// Ne jamais supprimer les lignes — utiliser revokedAt pour indiquer la fin.
model ImpersonationSession {
  id                    String    @id @default(uuid())
  actorId               String // User.id de l'agent SA ou Support
  actorTenantId         String // toujours "00000000-0000-0000-0000-000000000000"
  targetTenantId        String // tenant client ciblé
  token                 String    @unique // JWT signé (référence — non stocké en clair)
  tokenHash             String    @unique // SHA-256(token) — pour révocation sans stocker le token
  status                String    @default("ACTIVE") // ACTIVE | EXPIRED | REVOKED | EXCHANGED
  reason                String? // justification saisie par l'agent (audit)
  ipAddress             String?
  userAgent             String?
  expiresAt             DateTime
  revokedAt             DateTime?
  revokedBy             String? // userId qui a révoqué (peut être différent de actorId)
  // Phase 2 cross-subdomain : marque l'échange one-shot du token contre
  // un cookie de session sur le sous-domaine cible. Null = non échangé.
  // Une seconde tentative avec le même token est rejetée (anti-replay).
  exchangedAt           DateTime?
  // Session utilisateur créée via l'exchange (token opaque) — pour pouvoir
  // révoquer en cascade si on invalide l'impersonation a posteriori.
  exchangedSessionToken String?
  createdAt             DateTime  @default(now())

  @@index([actorId, createdAt])
  @@index([targetTenantId, createdAt])
  @@index([status, expiresAt])
  @@map("impersonation_sessions")
}

// ─────────────────────────────────────────────────────────────
// SECTION 6 : GÉOGRAPHIE & INFRASTRUCTURE
// ─────────────────────────────────────────────────────────────

model Station {
  id          String @id @default(cuid())
  tenantId    String
  name        String
  city        String @default("") // Ville de rattachement — hiérarchie Tenant > Ville > Gare
  coordinates Json // { lat: Float, lng: Float }
  type        String // PRINCIPALE | RELAIS

  tenant            Tenant              @relation(fields: [tenantId], references: [id])
  agencies          Agency[]
  routesOrigin      Route[]             @relation("RouteOrigin")
  routesDestination Route[]             @relation("RouteDestination")
  waypoints         Waypoint[]
  segmentsFrom      RouteSegmentPrice[] @relation("SegmentFrom")
  segmentsTo        RouteSegmentPrice[] @relation("SegmentTo")
  ticketsBoarding   Ticket[]            @relation("TicketBoarding")
  ticketsAlighting  Ticket[]            @relation("TicketAlighting")
  parcelsTo         Parcel[]            @relation("ParcelDestination")
  shipmentsTo       Shipment[]          @relation("ShipmentDestination")
  travelersDropoff  Traveler[]          @relation("TravelerDropOff")
  platforms         Platform[]
  announcements     Announcement[]

  @@index([tenantId])
  @@index([tenantId, city]) // Lookup multi-gares par ville (DisplayService scope=city)
  @@map("stations")
}

model Route {
  id                        String  @id @default(cuid())
  tenantId                  String
  name                      String
  originId                  String
  destinationId             String
  distanceKm                Float
  basePrice                 Float
  allowProportionalFallback Boolean @default(false)
  // Si true et qu'un segment n'a pas de prix configuré,
  // le pricing engine calcule proportionnellement à la distance.
  // Si false → vente bloquée ("Tarif non configuré").

  // TVA override par route (null = utilise le taux tenant)
  // Permet d'exonérer certaines lignes ou d'appliquer un taux réduit.
  tvaOverrideRate Float?

  tenant        Tenant              @relation(fields: [tenantId], references: [id])
  origin        Station             @relation("RouteOrigin", fields: [originId], references: [id])
  destination   Station             @relation("RouteDestination", fields: [destinationId], references: [id])
  waypoints     Waypoint[]
  segmentPrices RouteSegmentPrice[]
  trips         Trip[]
  tariffGrids   TariffGrid[]

  @@index([tenantId])
  @@map("routes")
}

model Waypoint {
  id                   String  @id @default(cuid())
  routeId              String
  stationId            String
  order                Int
  distanceFromOriginKm Float   @default(0) // km depuis l'origine
  tollCostXaf          Float   @default(0) // péages entre le waypoint précédent et celui-ci
  checkpointCosts      Json    @default("[]")
  // Array de charges intermédiaires entre le waypoint précédent et celui-ci.
  // Format : [{ type: "PEAGE"|"POLICE"|"DOUANE"|"EAUX_FORETS"|"FRONTIERE"|"AUTRE",
  //             name: "Poste Nganga", costXaf: 500 }]
  // costXaf = 0 si le point de contrôle n'implique pas de frais pour le bus.
  isMandatoryStop      Boolean @default(false)
  estimatedWaitTime    Int? // minutes
  isAlertZone          Boolean @default(false)
  alertDescription     String?

  route   Route   @relation(fields: [routeId], references: [id], onDelete: Cascade)
  station Station @relation(fields: [stationId], references: [id])

  @@unique([routeId, order])
  @@map("waypoints")
}

// ── Matrice de prix par paire de stations sur une route ──────────────────────
// Chaque entrée représente le tarif de base (avant classe/yield/taxes) pour
// un passager montant à fromStation et descendant à toStation.
// Prix = 0 signifie « non configuré » (vente bloquée sauf fallback autorisé).
model RouteSegmentPrice {
  id            String @id @default(cuid())
  routeId       String
  fromStationId String
  toStationId   String
  basePriceXaf  Float  @default(0) // 0 = non configuré

  route       Route   @relation(fields: [routeId], references: [id], onDelete: Cascade)
  fromStation Station @relation("SegmentFrom", fields: [fromStationId], references: [id])
  toStation   Station @relation("SegmentTo", fields: [toStationId], references: [id])

  @@unique([routeId, fromStationId, toStationId])
  @@index([routeId])
  @@map("route_segment_prices")
}

// ─────────────────────────────────────────────────────────────
// SECTION 7 : FLOTTE & PERSONNEL
// ─────────────────────────────────────────────────────────────

model Bus {
  id                String   @id @default(cuid())
  tenantId          String
  agencyId          String?
  plateNumber       String   @unique
  model             String
  type              String? // STANDARD | CONFORT | VIP | MINIBUS (validé côté DTO)
  year              Int?
  capacity          Int
  luggageCapacityKg Float
  luggageCapacityM3 Float
  seatLayout        Json? // Plan de salle numéroté — OBLIGATOIRE avant vente
  isFullVip         Boolean  @default(false) // true = tout le bus est VIP
  vipSeats          String[] @default([]) // Sièges VIP individuels (ex: ["1-1","1-2"]) — ignoré si isFullVip
  photos            String[] @default([]) // Clés MinIO des photos (intérieur/extérieur)
  amenities         String[] @default([]) // WIFI | AC | TOILETS | USB_CHARGING | RECLINING_SEATS | TV | SNACK_BAR | BLANKETS | LUGGAGE_TRACKING
  status            String   @default("AVAILABLE")
  // AVAILABLE | BOARDING | DEPARTED | ARRIVED | MAINTENANCE | CLOSED | IN_SERVICE
  version           Int      @default(1)

  // ── Champs techniques véhicule (optionnels) ─────────────────────────────
  vin                       String? // Numéro de châssis / VIN
  fuelType                  String? // DIESEL | PETROL | BIO_DIESEL | HYBRID | ELECTRIC
  engineType                String? // EURO_3 | EURO_4 | EURO_5 | EURO_6
  fuelTankCapacityL         Float? // Capacité réservoir carburant (litres)
  adBlueTankCapacityL       Float? // Capacité réservoir AdBlue (litres)
  registrationDate          DateTime? // Date de 1ère immatriculation
  purchaseDate              DateTime? // Date d'acquisition
  purchasePrice             Float? // Prix d'achat (XOF)
  initialOdometerKm         Float? // Kilométrage à l'enregistrement
  currentOdometerKm         Float? // Dernier relevé kilométrique connu
  fuelConsumptionPer100Km   Float? // Consommation déclarée/constructeur (L/100km)
  adBlueConsumptionPer100Km Float? // Consommation AdBlue déclarée (L/100km) — moteurs Euro 6

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  agency              Agency?              @relation(fields: [agencyId], references: [id])
  trips               Trip[]
  maintenanceReports  MaintenanceReport[]
  costProfile         BusCostProfile?
  vehicleDocuments    VehicleDocument[]
  consumableTrackings ConsumableTracking[]
  fuelLogs            FuelLog[]
  odometerReadings    OdometerReading[]

  @@index([tenantId, status])
  @@index([tenantId, agencyId])
  @@map("buses")
}

// ─── Suivi kilométrique — relevés d'odomètre horodatés ──────────────────────
model OdometerReading {
  id          String   @id @default(cuid())
  tenantId    String
  busId       String
  readingKm   Float // Valeur odomètre (km)
  readingDate DateTime @default(now()) // Date/heure du relevé
  source      String   @default("MANUAL") // MANUAL | TRIP | MAINTENANCE | GPS
  note        String?
  createdById String? // Utilisateur ayant saisi le relevé

  tenant Tenant @relation(fields: [tenantId], references: [id])
  bus    Bus    @relation(fields: [busId], references: [id])

  @@index([tenantId, busId])
  @@index([busId, readingDate])
  @@map("odometer_readings")
}

// ─── Suivi carburant & AdBlue ────────────────────────────────────────────────
model FuelLog {
  id          String   @id @default(cuid())
  tenantId    String
  busId       String
  logDate     DateTime @default(now()) // Date/heure du plein
  fuelType    String // DIESEL | PETROL | ADBLUE
  quantityL   Float // Quantité (litres)
  pricePerL   Float? // Prix unitaire (XOF/litre)
  totalCost   Float? // Coût total (XOF) — calculé ou saisi
  odometerKm  Float? // Kilométrage au moment du plein
  stationName String? // Nom de la station-service
  fullTank    Boolean  @default(false) // Plein complet (pour calcul consommation réelle)
  note        String?
  createdById String? // Utilisateur ayant saisi le plein

  tenant Tenant @relation(fields: [tenantId], references: [id])
  bus    Bus    @relation(fields: [busId], references: [id])

  @@index([tenantId, busId])
  @@index([busId, logDate])
  @@map("fuel_logs")
}

// ─── PERSONNEL : Staff (enveloppe RH) + StaffAssignment (postes occupés) ───
//
// Staff représente l'enveloppe RH d'un employé du tenant (paie, rattachement
// administratif, statut global). Les postes métier effectivement occupés
// (rôle, agence, licence, dispo) sont portés par StaffAssignment — un Staff
// peut avoir 0..N affectations.
//
// Voir DESIGN_Staff_Assignment.md (sections 4.1 à 4.3).
//
// Phase 5 : colonnes legacy (role/licenseData/isAvailable/totalDriveTimeToday)
// supprimées — toutes les requêtes métier passent désormais par
// StaffAssignment. Voir DESIGN_Staff_Assignment.md §6.
model Staff {
  id        String   @id @default(cuid())
  tenantId  String
  agencyId  String? // agence de rattachement administratif (RH/paie)
  userId    String   @unique
  status    String   @default("ACTIVE") // ACTIVE | SUSPENDED | ARCHIVED
  hireDate  DateTime @default(now()) // date d'embauche (RH)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user        User              @relation(fields: [userId], references: [id])
  assignments StaffAssignment[]

  @@index([tenantId, status])
  @@map("staff")
}

// StaffAssignment — un poste occupé par un Staff sur une agence ou sur tout le tenant.
//
// Couverture (voir DESIGN_Staff_Assignment.md §4.3) :
//   agencyId renseigné, pas de coverageAgencies  → MONO (1 agence)
//   agencyId null, pas de coverageAgencies       → TENANT-WIDE (toutes)
//   agencyId null, N coverageAgencies            → MULTI-SPÉCIFIQUE (N agences)
// Combinaison interdite : agencyId renseigné + coverageAgencies (validation applicative).
//
// Clôture plutôt que suppression : endDate + status=CLOSED pour préserver l'historique.
model StaffAssignment {
  id                  String    @id @default(cuid())
  staffId             String
  role                String // DRIVER | HOSTESS | MECHANIC | AGENT | CONTROLLER | SUPERVISOR
  agencyId            String? // null + 0 coverageAgencies = tenant-wide ; null + N = multi-spécifique
  startDate           DateTime  @default(now())
  endDate             DateTime? // null = affectation active
  status              String    @default("ACTIVE") // ACTIVE | SUSPENDED | CLOSED
  licenseData         Json      @default("{}")
  isAvailable         Boolean   @default(true)
  totalDriveTimeToday Float     @default(0) // pertinent si role=DRIVER — reset par scheduler minuit
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  staff            Staff                   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  agency           Agency?                 @relation(fields: [agencyId], references: [id])
  coverageAgencies StaffAssignmentAgency[]

  @@index([staffId, status])
  @@index([role, status, isAvailable])
  @@index([agencyId, role, status])
  @@map("staff_assignments")
}

// StaffAssignmentAgency — table de jointure pour le cas multi-spécifique.
// Ne pas utiliser si StaffAssignment.agencyId est renseigné (validation applicative).
model StaffAssignmentAgency {
  assignmentId String
  agencyId     String
  createdAt    DateTime @default(now())

  assignment StaffAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  agency     Agency          @relation(fields: [agencyId], references: [id])

  @@id([assignmentId, agencyId])
  @@index([agencyId])
  @@map("staff_assignment_agencies")
}

// ─────────────────────────────────────────────────────────────
// SECTION 8 : TRAJETS & OPÉRATIONS
// ─────────────────────────────────────────────────────────────

model Trip {
  id                 String    @id @default(cuid())
  tenantId           String
  routeId            String
  busId              String
  driverId           String
  status             String    @default("PLANNED")
  // PLANNED | OPEN | BOARDING | IN_PROGRESS | IN_PROGRESS_PAUSED
  // IN_PROGRESS_DELAYED | COMPLETED | CANCELLED
  seatingMode        String    @default("FREE")
  // FREE = placement libre (pas de choix de siège, mais capacité respectée)
  // NUMBERED = places numérotées (siège attribué auto ou choisi via option payante)
  roadbook           Json      @default("{}")
  // Stocké en DB (pas MinIO) pour permettre les requêtes sur waypoints
  departureScheduled DateTime
  arrivalScheduled   DateTime
  currentLat         Float?
  currentLng         Float?
  lastGpsAt          DateTime?
  displayNote        String? // texte court pour écrans d'affichage gare
  displayColor       String? // code couleur hex (#FF9800 = ambre retard)
  version            Int       @default(1)

  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  route           Route             @relation(fields: [routeId], references: [id])
  bus             Bus               @relation(fields: [busId], references: [id])
  checklists      Checklist[]
  incidents       Incident[]
  shipments       Shipment[]
  tripEvents      TripEvent[]
  crewAssignments CrewAssignment[]
  feedbacks       Feedback[]
  travelers       Traveler[]        @relation("TripTravelers")
  costSnapshot    TripCostSnapshot?
  manifests       Manifest[]

  @@index([tenantId, status])
  @@index([tenantId, departureScheduled])
  @@map("trips")
}

// Manifest = document récapitulatif d'un trajet (passagers ET/OU colis).
//
// Depuis 2026-04-19 : chaque kind (ALL | PASSENGERS | PARCELS) a sa propre
// entité Manifest, signée indépendamment. La signature déclenche la génération
// du PDF figé (signedPdfStorageKey) qui est la source de vérité du contenu
// à l'instant T.
//
// Cycle de vie — blueprint `manifest-standard` (cf. prisma/seed/seed.ts:220) :
//   DRAFT → submit → SUBMITTED → sign → SIGNED → archive → ARCHIVED
//                                  → reject → REJECTED → revise → DRAFT
//
// Les transitions DOIVENT passer par WorkflowEngine.transition() pour
// respecter le contrat permissions/guards/audit. Voir ManifestService.
model Manifest {
  id       String @id @default(cuid())
  tenantId String
  tripId   String
  kind     String @default("ALL")
  // ALL | PASSENGERS | PARCELS — pilote le contenu du PDF figé
  status   String @default("DRAFT")
  // DRAFT | SUBMITTED | SIGNED | REJECTED | ARCHIVED — aligné blueprint manifest-standard
  version  Int    @default(1)

  // PDF placeholder (upload direct mobile optionnel) + PDF figé généré à la signature
  storageKey          String?
  signedPdfStorageKey String?

  // Compteurs figés à la génération — utilisés pour reporting et affichage cockpit
  passengerCount Int @default(0)
  parcelCount    Int @default(0)

  // Signature SVG (taille bornée 256 KB côté service — chain of custody audit)
  signatureSvg String?
  signedAt     DateTime?
  signedById   String?

  generatedAt   DateTime @default(now())
  generatedById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  trip        Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  generatedBy User   @relation("ManifestGenerator", fields: [generatedById], references: [id])
  signedBy    User?  @relation("ManifestSigner", fields: [signedById], references: [id])

  // Un seul manifeste par (trip, kind) — pas de duplication
  @@unique([tenantId, tripId, kind])
  @@index([tenantId, status])
  @@index([tenantId, tripId])
  @@index([tenantId, signedAt])
  @@map("manifests")
}

model Checklist {
  id          String   @id @default(cuid())
  tenantId    String?  // nullable rétro-compat legacy rows ; nouveau code écrit toujours le tenantId
  tripId      String
  userId      String
  type        String
  // PRE_DEPARTURE | BOARDING_READY | POST_TRIP | MAINTENANCE
  content     Json     @default("{}")
  isCompliant Boolean  @default(false)
  status      String   @default("PENDING")
  // PENDING | TECH_CHECK | SAFETY_CHECK | DOCS_CHECK | APPROVED | BLOCKED — aligné blueprint checklist-departure
  version     Int      @default(1)
  createdAt   DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([tripId, type])
  @@index([tenantId, status])
  @@map("checklists")
}

// Incident: événement exceptionnel nécessitant une réponse humaine (SOS, panne, etc.)
// Partage l'interface BaseEvent avec TripEvent — voir src/common/types/base-event.type.ts
model Incident {
  id                  String    @id @default(cuid())
  tenantId            String
  tripId              String?
  busId               String?
  reportedById        String
  type                String // MECHANICAL | SECURITY | HEALTH | LOST_OBJECT | SOS | ACCIDENT
  severity            String // LOW | MEDIUM | HIGH | CRITICAL
  description         String
  locationDescription String?
  metadata            Json      @default("{}")
  isSos               Boolean   @default(false)
  status              String    @default("OPEN")
  // OPEN | ASSIGNED | IN_PROGRESS | RESOLVED | CLOSED — aligné blueprint incident-response
  version             Int       @default(1)
  assigneeId          String?
  resolution          String?
  resolvedAt          DateTime?
  claimId             String? // FK vers Claim si incident déclenche un SAV
  createdAt           DateTime  @default(now())

  trip Trip? @relation(fields: [tripId], references: [id])

  @@index([tenantId, tripId, type])
  @@index([tenantId, severity, resolvedAt])
  @@index([tenantId, isSos, status])
  @@map("incidents")
}

model MaintenanceReport {
  id            String    @id @default(cuid())
  tenantId      String
  busId         String
  incidentId    String?
  type          String // PREVENTIVE | CORRECTIVE | EMERGENCY
  description   String
  scheduledAt   DateTime
  odometer      Float?
  partsUsed     Json      @default("[]")
  status        String    @default("SCHEDULED")
  // SCHEDULED | IN_PROGRESS | COMPLETED | APPROVED — aligné blueprint maintenance-standard
  version       Int       @default(1)
  notes         String?
  createdById   String
  completedAt   DateTime?
  completedById String?
  approvedById  String?
  approvedAt    DateTime?
  createdAt     DateTime  @default(now())

  bus          Bus                      @relation(fields: [busId], references: [id])
  intervenants MaintenanceIntervenant[]
  parts        MaintenancePart[]

  @@index([tenantId, busId])
  @@index([tenantId, status])
  @@map("maintenance_reports")
}

// ─────────────────────────────────────────────────────────────
// SECTION 9 : BILLETTERIE & PASSAGERS
// ─────────────────────────────────────────────────────────────

model Ticket {
  id                 String    @id @default(cuid())
  tenantId           String
  tripId             String
  // Nullable : un billet peut être émis pour un client non authentifié
  // (caisse, guichet, portail anonyme). La traçabilité CRM se fait via
  // customerId ; passengerId reste la FK "user logué/connecté" si présent.
  passengerId        String?
  passengerName      String
  // Contacts dénormalisés — permettent la recherche rapide et le backfill CRM
  // (source de vérité = Customer via customerId quand disponible).
  passengerPhone     String?
  passengerEmail     String?
  // FK vers l'entité CRM canonique (présente dès que phone ou email sont fournis).
  customerId         String?
  seatNumber         String?
  boardingStationId  String // Gare de montée (défaut = route.originId)
  alightingStationId String // Gare de descente (défaut = route.destinationId)
  fareClass          String    @default("STANDARD") // STANDARD | CONFORT | VIP | STANDING
  pricePaid          Float
  status             String    @default("CREATED")
  // CREATED | PENDING_PAYMENT | CONFIRMED | CHECKED_IN | BOARDED | COMPLETED
  // CANCELLED | EXPIRED
  expiresAt          DateTime?
  qrCode             String    @unique
  // Format: base64url(payload).HMAC-SHA256(payload, tenant_hmac_key)
  agencyId           String?
  version            Int       @default(1)
  createdAt          DateTime  @default(now())

  boardingStation  Station   @relation("TicketBoarding", fields: [boardingStationId], references: [id])
  alightingStation Station   @relation("TicketAlighting", fields: [alightingStationId], references: [id])
  customer         Customer? @relation(fields: [customerId], references: [id])

  @@index([tenantId, tripId, status])
  @@index([qrCode])
  @@index([tenantId, agencyId])
  @@index([tenantId, customerId])
  @@index([tenantId, passengerPhone])
  @@map("tickets")
}

model Traveler {
  id               String  @id @default(cuid())
  tenantId         String
  ticketId         String  @unique
  tripId           String
  status           String  @default("VERIFIED")
  // VERIFIED | CHECKED_IN | BOARDED | ARRIVED | EXITED
  dropOffStationId String?
  version          Int     @default(1)

  dropOffStation Station? @relation("TravelerDropOff", fields: [dropOffStationId], references: [id])
  trip           Trip     @relation("TripTravelers", fields: [tripId], references: [id])

  @@index([tenantId, tripId, status])
  @@index([tripId, dropOffStationId])
  @@map("travelers")
}

model Baggage {
  id        String @id @default(cuid())
  tenantId  String
  ticketId  String
  count     Int    @default(1)
  weight    Float
  type      String // CABIN | HOLD
  surcharge Float  @default(0)

  @@index([ticketId])
  @@map("baggages")
}

// ─────────────────────────────────────────────────────────────
// SECTION 10 : COLIS & EXPÉDITIONS
// ─────────────────────────────────────────────────────────────

model Parcel {
  id                  String   @id @default(cuid())
  tenantId            String
  // Nullable : un colis peut être enregistré pour un expéditeur non
  // authentifié. La traçabilité CRM passe par senderCustomerId.
  senderId            String?
  trackingCode        String   @unique
  weight              Float
  price               Float
  destinationId       String // FK Station (plus un String libre)
  recipientInfo       Json // { name, phone, address } — legacy ; conservé en miroir
  //                   pendant la transition vers recipientCustomerId
  // FK CRM canoniques (présentes dès que phone ou email sont fournis).
  senderCustomerId    String?
  recipientCustomerId String?
  shipmentId          String?
  status              String   @default("CREATED")
  // CREATED | AT_ORIGIN | PACKED | LOADED | IN_TRANSIT | ARRIVED | DELIVERED | DAMAGED
  history             Json     @default("[]")
  // [{ timestamp, agentId, stationId, action }]
  version             Int      @default(1)
  createdAt           DateTime @default(now())

  tenant            Tenant    @relation(fields: [tenantId], references: [id])
  destination       Station   @relation("ParcelDestination", fields: [destinationId], references: [id])
  shipment          Shipment? @relation(fields: [shipmentId], references: [id])
  senderCustomer    Customer? @relation("ParcelSender", fields: [senderCustomerId], references: [id])
  recipientCustomer Customer? @relation("ParcelRecipient", fields: [recipientCustomerId], references: [id])

  @@index([tenantId, status])
  @@index([trackingCode])
  @@index([tenantId, destinationId])
  @@index([tenantId, senderCustomerId])
  @@index([tenantId, recipientCustomerId])
  @@map("parcels")
}

// ─────────────────────────────────────────────────────────────
// SECTION 10.bis : CRM — CUSTOMER CANONIQUE
// ─────────────────────────────────────────────────────────────
// Customer = identité CRM tenant-scoped, indépendante du User.
//   - Créé au 1er contact (ticket / colis), même si anonyme.
//   - Lié à un User si la personne s'inscrit (userId one-to-one).
//   - Clé de matching : (tenantId, phoneE164). Email secondaire.
//   - phoneE164 nullable pour les cas email-only (achat web).
// Source de vérité pour segmentation, fidélité, campaigns.

model Customer {
  id              String    @id @default(cuid())
  tenantId        String
  phoneE164       String? // E.164 normalisé, clé de matching primaire
  email           String?
  name            String
  firstName       String?
  lastName        String?
  language        String? // ISO 639-1 (fr, en, wo…) — préférence contact
  // userId = null → shadow profile (anonyme, jamais connecté)
  userId          String?   @unique
  preferences     Json      @default("{}")
  // { favoriteSeatType, favoriteSeatNumber, favoriteRoute, channels: { sms, whatsapp, email } }
  segments        String[]  @default([])
  // Ex. ['VIP', 'FREQUENT', 'CORPORATE'] — dérivés ou édités
  totalTickets    Int       @default(0)
  totalParcels    Int       @default(0)
  // Centimes (ou plus petite unité de la devise tenant) — JAMAIS Float sur un compteur monétaire
  totalSpentCents BigInt    @default(0)
  firstSeenAt     DateTime  @default(now())
  lastSeenAt      DateTime  @default(now())
  // Soft-delete / RGPD : anonymisation sans perdre les agrégats financiers
  deletedAt       DateTime?
  // Fusion : si mergé dans un autre Customer, pointe vers la survivante
  mergedIntoId    String?

  tenant             Tenant               @relation(fields: [tenantId], references: [id])
  user               User?                @relation("UserCustomerProfile", fields: [userId], references: [id])
  tickets            Ticket[]
  parcelsAsSender    Parcel[]             @relation("ParcelSender")
  parcelsAsRecipient Parcel[]             @relation("ParcelRecipient")
  claimTokens        CustomerClaimToken[]
  paymentIntents     PaymentIntent[]

  // Unicité par tenant — phone et email peuvent être NULL (plusieurs NULL tolérés par PG)
  @@unique([tenantId, phoneE164])
  @@unique([tenantId, email])
  @@index([tenantId, lastSeenAt])
  @@index([tenantId, deletedAt])
  @@map("customers")
}

// Token de claim (magic link) envoyé post-transaction anonyme.
//   - On stocke le HASH (sha-256), jamais le token en clair.
//   - Un nouveau token invalide les précédents du même Customer (invalidatedAt).
//   - usedAt ≠ null ⇒ one-shot, plus utilisable.

model CustomerClaimToken {
  id            String    @id @default(cuid())
  tenantId      String
  customerId    String
  tokenHash     String    @unique // sha-256(token) — le token clair n'est jamais stocké
  channel       String // MAGIC_EMAIL | MAGIC_WHATSAPP | MAGIC_SMS
  expiresAt     DateTime
  usedAt        DateTime?
  invalidatedAt DateTime?
  createdAt     DateTime  @default(now())
  createdByIp   String?

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, usedAt, invalidatedAt])
  @@index([tenantId, expiresAt])
  @@map("customer_claim_tokens")
}

// OTP SMS/WhatsApp pour le claim RÉTROACTIF (Phase 3).
// Quand l'utilisateur retrouve un colis/billet avec son phone APRÈS expiration
// du magic link : on lui envoie un code à 6 chiffres (TTL 5min, 5 essais max).
//   - On stocke le HASH (sha-256), jamais l'OTP en clair.
//   - 1 OTP actif par (phone, target) ; nouvelle initiation invalide l'ancien.
//   - usedAt ≠ null ⇒ one-shot.
//   - attempts ≥ 5 ⇒ OTP détruit (équivalent à expiré).

model CustomerRetroClaimOtp {
  id            String    @id @default(cuid())
  tenantId      String
  phoneE164     String // clef de lookup, normalisé côté service
  otpHash       String // sha-256(otp)
  targetType    String // TICKET | PARCEL
  targetId      String // ticket.id ou parcel.id (qrCode/trackingCode résolu)
  attempts      Int       @default(0) // compteur brute-force
  expiresAt     DateTime // now + 5 min
  usedAt        DateTime?
  invalidatedAt DateTime?
  createdAt     DateTime  @default(now())
  createdByIp   String?

  @@index([tenantId, phoneE164, usedAt])
  @@index([tenantId, phoneE164, createdAt]) // pour le rate-limit 3/jour/phone
  @@map("customer_retro_claim_otps")
}

model Shipment {
  id              String   @id @default(cuid())
  tenantId        String
  tripId          String
  destinationId   String // FK Station (plus un String libre)
  totalWeight     Float    @default(0)
  remainingWeight Float
  status          String   @default("OPEN")
  // OPEN | LOADED | IN_TRANSIT | ARRIVED | CLOSED
  version         Int      @default(1)
  createdAt       DateTime @default(now())

  trip        Trip     @relation(fields: [tripId], references: [id])
  destination Station  @relation("ShipmentDestination", fields: [destinationId], references: [id])
  parcels     Parcel[]

  @@index([tenantId, tripId])
  @@map("shipments")
}

// ─────────────────────────────────────────────────────────────
// SECTION 11 : FINANCE & CAISSE
// ─────────────────────────────────────────────────────────────

model PricingRules {
  id       String @id @default(cuid())
  tenantId String
  routeId  String
  rules    Json
  // {
  //   basePrice: Float, taxRate: Float, tollCost: Float,
  //   pricePerKm: Float, luggageQuotaKg: Float, surchargePerKg: Float,
  //   yieldConfig: { enabled: Boolean, tiers: [...] }
  // }

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, routeId])
  @@map("pricing_rules")
}

model CashRegister {
  id             String    @id @default(cuid())
  tenantId       String
  agencyId       String
  agentId        String
  openedAt       DateTime  @default(now())
  closedAt       DateTime?
  initialBalance Float
  finalBalance   Float?
  status         String    @default("OPEN")
  // OPEN | CLOSED | DISCREPANCY — aligné blueprint cash-register-cycle
  version        Int       @default(1)

  agency       Agency        @relation(fields: [agencyId], references: [id])
  transactions Transaction[]

  @@index([tenantId, agencyId, status])
  @@map("cash_registers")
}

model Transaction {
  id             String   @id @default(cuid())
  tenantId       String
  cashRegisterId String
  type           String // TICKET | PARCEL | LUGGAGE_FEE | REFUND
  amount         Float
  paymentMethod  String // CASH | MOBILE_MONEY
  externalRef    String? // Référence Flutterwave/Paystack (idempotent)
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())

  cashRegister CashRegister @relation(fields: [cashRegisterId], references: [id])

  @@index([tenantId, createdAt])
  @@index([externalRef])
  @@map("transactions")
}

// ─────────────────────────────────────────────────────────────
// SECTION 12 : SAV & OBJETS TROUVÉS
// ─────────────────────────────────────────────────────────────

model LostFoundItem {
  id           String    @id @default(cuid())
  tenantId     String
  tripId       String
  reporterId   String
  description  String
  photoUrl     String? // MinIO signed URL — TTL 30 jours post-remise
  status       String    @default("FOUND")
  // FOUND | CLAIMED | DISPOSED
  claimedAt    DateTime?
  claimedBy    String?
  signatureUrl String? // Photo pièce ID — TTL 15min (biométrique)
  createdAt    DateTime  @default(now())

  @@index([tenantId, status])
  @@map("lost_found_items")
}

model Claim {
  id          String    @id @default(cuid())
  tenantId    String
  type        String // PARCEL_DAMAGE | PARCEL_LOSS | SERVICE | REFUND_REQUEST | SAFETY
  reporterId  String
  entityId    String // parcelId ou ticketId
  entityType  String // PARCEL | TICKET | INCIDENT
  description String
  status      String    @default("OPEN")
  // OPEN | UNDER_INVESTIGATION | RESOLVED | REJECTED | CLOSED — aligné blueprint claim-sav
  version     Int       @default(1)
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime  @default(now())

  @@index([tenantId, status])
  @@map("claims")
}

// ─────────────────────────────────────────────────────────────
// SECTION 12b : REFUNDS (remboursements billets — PRD §IV.12)
// ─────────────────────────────────────────────────────────────

model Refund {
  id             String    @id @default(cuid())
  tenantId       String
  ticketId       String
  tripId         String?
  // Montant effectif du remboursement (= originalAmount × policyPercent).
  amount         Float
  // Montant original du billet (pricePaid) — audit trail.
  originalAmount Float?
  // Pourcentage appliqué (0.0–1.0) selon la politique d'annulation du tenant.
  policyPercent  Float?
  currency       String    @default("XAF")
  reason         String // CLIENT_CANCEL | TRIP_CANCELLED
  status         String    @default("PENDING")
  // PENDING | APPROVED | PROCESSED | REJECTED
  paymentMethod  String?
  // Canal de la demande : CASHIER | PORTAL | SYSTEM
  requestChannel String?
  // userId ayant initié la demande (ou 'SYSTEM')
  requestedBy    String?
  // Snapshot de l'heure de départ du trajet au moment de la demande
  departureAt    DateTime?
  approvedBy     String?
  approvedAt     DateTime?
  processedBy    String?
  processedAt    DateTime?
  rejectedBy     String?
  rejectedAt     DateTime?
  notes          String?
  // Lock optimiste — requis par le WorkflowEngine (SELECT FOR UPDATE + version check).
  version        Int       @default(1)
  createdAt      DateTime  @default(now())

  @@index([tenantId, status])
  @@index([tenantId, ticketId])
  @@map("refunds")
}

// ─────────────────────────────────────────────────────────────
// SECTION 13 : TRIP EVENTS (pauses, checkpoints, délais — PRD §IV.11)
// ─────────────────────────────────────────────────────────────

// TripEvent: événements opérationnels normaux du voyage (pauses, checkpoints GPS, délais)
// Partage l'interface BaseEvent avec Incident — discriminé par le champ type
model TripEvent {
  id         String   @id @default(cuid())
  tenantId   String
  tripId     String
  type       String
  // PAUSE_START | PAUSE_END | CHECKPOINT_REACHED | DELAY_DECLARED
  // DELAY_DETECTED | DEPARTURE_ANOMALY | GEOFENCE_EXIT
  severity   String   @default("LOW") // LOW | MEDIUM | HIGH | CRITICAL
  reportedBy String // userId du chauffeur ou 'SYSTEM'
  gpsLat     Float?
  gpsLng     Float?
  metadata   Json     @default("{}") // durée pause, nom checkpoint, etc.
  claimId    String? // FK Claim si l'événement déclenche un SAV
  createdAt  DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id])

  @@index([tenantId, tripId, type])
  @@index([tenantId, createdAt])
  @@map("trip_events")
}

// ─────────────────────────────────────────────────────────────
// SECTION 14 : SAFETY & FEEDBACK (PRD §IV.13)
// ─────────────────────────────────────────────────────────────

model SafetyAlert {
  id                String   @id @default(cuid())
  tenantId          String
  tripId            String?
  reporterId        String
  type              String // DANGEROUS_DRIVING | ACCIDENT | BREAKDOWN | OTHER
  description       String?
  gpsLat            Float?
  gpsLng            Float?
  verificationScore Float    @default(0) // 0..1 — corrélation GPS bus/déclarant
  status            String   @default("PENDING")
  // PENDING | VERIFIED | UNVERIFIED | DISMISSED
  source            String   @default("IN_APP") // IN_APP | PUBLIC_REPORT
  createdAt         DateTime @default(now())

  reporter User @relation(fields: [reporterId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, tripId])
  @@map("safety_alerts")
}

// Feedback: note brute soumise par un voyageur après un trajet
model Feedback {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String
  tripId        String?
  driverId      String? // Staff.id
  busId         String?
  agencyId      String?
  ratings       Json     @default("{}")
  // { conduct: 0-5, punctuality: 0-5, comfort: 0-5, baggage: 0-5 }
  comment       String?
  rgpdConsentAt DateTime // consentement RGPD obligatoire à la soumission
  createdAt     DateTime @default(now())

  user User  @relation(fields: [userId], references: [id])
  trip Trip? @relation(fields: [tripId], references: [id])

  @@index([tenantId, tripId])
  @@index([driverId])
  @@index([busId])
  @@map("feedbacks")
}

// Rating: agrégat calculé — mis à jour asynchroniquement via side effect trip.completed
model Rating {
  id         String   @id @default(cuid())
  tenantId   String
  entityType String // DRIVER | BUS | AGENCY
  entityId   String // Staff.id | Bus.id | Agency.id
  avgScore   Float    @default(0)
  count      Int      @default(0)
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, entityType, entityId])
  @@index([tenantId, entityType])
  @@map("ratings")
}

// ─────────────────────────────────────────────────────────────
// SECTION 15 : CREW OPERATIONS (PRD §IV.15)
// ─────────────────────────────────────────────────────────────

model CrewAssignment {
  id        String    @id @default(cuid())
  tenantId  String
  tripId    String
  staffId   String
  crewRole  String // CO_PILOT | HOSTESS | SECURITY | MECHANIC_ON_BOARD
  briefedAt DateTime? // null = pas encore briefé (guard CREW_BRIEFED)
  status    String    @default("STANDBY")
  // STANDBY | BRIEFING | ON_DUTY | DEBRIEFING | REST | SUSPENDED — aligné blueprint crew-assignment
  version   Int       @default(1)
  createdAt DateTime  @default(now())

  trip           Trip                @relation(fields: [tripId], references: [id])
  briefingRecord CrewBriefingRecord?

  @@unique([tripId, staffId])
  @@index([tenantId, tripId])
  @@index([tenantId, status])
  @@map("crew_assignments")
}

// ─────────────────────────────────────────────────────────────
// SECTION 16 : PUBLIC REPORTER (PRD §IV.16)
// ─────────────────────────────────────────────────────────────

model PublicReport {
  id                  String    @id @default(cuid())
  tenantId            String
  plateOrParkNumber   String
  type                String // DANGEROUS_DRIVING | ACCIDENT | BREAKDOWN | OTHER
  description         String
  reporterGpsLat      Float?
  reporterGpsLng      Float?
  reporterGpsExpireAt DateTime? // RGPD: suppression GPS après 24h
  verificationScore   Float     @default(0)
  status              String    @default("PENDING")
  // PENDING | VERIFIED | UNVERIFIED | DISMISSED
  correlatedBusId     String?
  photoUrl            String?
  reporterIp          String // pour rate limiting audit
  createdAt           DateTime  @default(now())

  @@index([tenantId, status])
  @@index([plateOrParkNumber])
  @@map("public_reports")
}

// ─────────────────────────────────────────────────────────────
// SECTION 17 : CRM & CAMPAGNES (PRD §IV.12)
// ─────────────────────────────────────────────────────────────

model Campaign {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  criteria    Json     @default("{}") // segments de voyageurs ciblés
  messageText String
  status      String   @default("DRAFT")
  // DRAFT | ACTIVE | PAUSED | COMPLETED
  sentCount   Int      @default(0)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, status])
  @@map("campaigns")
}

// ─────────────────────────────────────────────────────────────
// SECTION 17 : GPS & TEMPLATES
// ─────────────────────────────────────────────────────────────

model GpsPosition {
  id         String   @id @default(cuid())
  tenantId   String
  tripId     String
  lat        Float
  lng        Float
  speed      Float?
  heading    Float?
  recordedAt DateTime @default(now())

  @@index([tenantId, tripId, recordedAt])
  @@map("gps_positions")
}

model TripTemplate {
  id              String    @id @default(cuid())
  tenantId        String
  routeId         String
  weekdays        Json // [0..6] jours de la semaine
  departureTime   String // "HH:MM"
  defaultBusId    String?
  defaultDriverId String?
  isActive        Boolean   @default(true)
  effectiveUntil  DateTime?
  createdAt       DateTime  @default(now())

  @@index([tenantId, isActive])
  @@map("trip_templates")
}

// ─────────────────────────────────────────────────────────────
// SECTION 19 : WORKFLOW STUDIO & MARKETPLACE (PRD §V.5)
// ─────────────────────────────────────────────────────────────

/// Catégorie de blueprint (ex: "Billetterie", "Logistique", "Support")
model BlueprintCategory {
  id         String              @id @default(cuid())
  name       String              @unique
  slug       String              @unique
  icon       String?
  sortOrder  Int                 @default(0)
  blueprints WorkflowBlueprint[]

  @@map("blueprint_categories")
}

/// Blueprint réutilisable de workflow — modèle de machine d'état exportable/importable.
/// Un blueprint est un snapshot figé d'un graphe de workflow : il ne change jamais
/// une fois publié (immutable history). Pour modifier, on publie une nouvelle version.
model WorkflowBlueprint {
  id             String             @id @default(cuid())
  name           String
  slug           String
  description    String?
  entityType     String // Ticket | Parcel | Trip | Claim
  /// Graphe sérialisé comme WorkflowGraph JSON (nodes + edges)
  graphJson      Json
  /// SHA-256 de graphJson — tamper detection à l'import
  checksum       String
  version        String             @default("1.0.0")
  isPublic       Boolean            @default(false) // false = PRIVATE (visible qu'à authorTenantId)
  isSystem       Boolean            @default(false) // true = seed système non supprimable
  categoryId     String?
  category       BlueprintCategory? @relation(fields: [categoryId], references: [id])
  /// Tenant auteur (null = blueprint système)
  authorTenantId String?
  /// Tags de recherche
  tags           Json               @default("[]") // string[]
  /// Compteur installations (dénormalisé pour ranking marketplace)
  usageCount     Int                @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  installs BlueprintInstall[]

  @@unique([authorTenantId, slug, version])
  @@index([entityType, isPublic])
  @@index([isSystem])
  @@map("workflow_blueprints")
}

/// Installation d'un blueprint par un tenant.
/// Chaque installation snapshot le graphJson au moment de l'install
/// pour que les mises à jour du blueprint n'affectent pas les tenants existants.
model BlueprintInstall {
  id           String            @id @default(cuid())
  tenantId     String
  blueprintId  String
  blueprint    WorkflowBlueprint @relation(fields: [blueprintId], references: [id])
  /// Snapshot du graphJson au moment de l'installation
  snapshotJson Json
  /// Indique si le tenant a personnalisé le workflow après l'installation
  isDirty      Boolean           @default(false)
  installedAt  DateTime          @default(now())
  installedBy  String // userId

  @@unique([tenantId, blueprintId])
  @@index([tenantId])
  @@map("blueprint_installs")
}

// ─────────────────────────────────────────────────────────────
// SECTION 18 : DOCUMENT TEMPLATES (PRD §Render Engine)
// ─────────────────────────────────────────────────────────────

model DocumentTemplate {
  id          String   @id @default(cuid())
  // tenantId null = template système (partagé entre tous les tenants)
  tenantId    String?
  name        String // Nom lisible : "Billet A4 FR"
  slug        String // Identifiant machine : "ticket-a4-fr"
  docType     String // TICKET | MANIFEST | INVOICE | LABEL | PACKING_LIST
  format      String // A4 | A5 | THERMAL_80MM | LABEL_62MM | ENVELOPE_C5 | BAGGAGE_TAG
  engine      String   @default("HBS") // HBS | PUPPETEER | PDFME
  // Chemin MinIO vers le fichier source .hbs (null = template inline stocké dans `body`)
  storageKey  String?
  // Template source inline (utilisé si storageKey null — évite un round-trip MinIO)
  body        String?
  // Schéma pdfme JSON (engine=PDFME uniquement) — Template + schemas au format @pdfme/common
  schemaJson  Json?
  // Variables requises déclarées comme JSON Schema
  varsSchema  Json     @default("{}")
  version     Int      @default(1)
  isSystem    Boolean  @default(false) // Ne peut pas être supprimé par un tenant
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false) // Un seul défaut par docType par tenant
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, slug, version])
  @@index([docType, isActive])
  @@index([tenantId, isActive])
  @@index([tenantId, docType, isDefault])
  @@map("document_templates")
}

// ─────────────────────────────────────────────────────────────
// SECTION 20 : RENTABILITÉ & YIELD MANAGEMENT
// ─────────────────────────────────────────────────────────────

// ── Profil de coût par véhicule (paramétrable par le tenant) ──────────────────
// Sert de base au calcul ProfitabilityService pour chaque trajet.
model BusCostProfile {
  id                      String   @id @default(cuid())
  tenantId                String
  busId                   String   @unique
  // Coûts variables directs
  fuelConsumptionPer100Km Float // litres / 100 km
  fuelPricePerLiter       Float // prix actuel du carburant (XOF/litre)
  // AdBlue — moteurs Euro 6 (Mercedes Actros, Iveco Stralis…)
  adBlueCostPerLiter      Float    @default(0.18) // coût AdBlue au litre (€)
  adBlueRatioFuel         Float    @default(0.05) // fraction AdBlue / volume carburant
  // Maintenance au km (ADR-23 — remplace forfait mensuel biaisé)
  maintenanceCostPerKm    Float    @default(0.05) // coût d'entretien par km (XOF/km)
  // Frais de départ
  stationFeePerDeparture  Float    @default(0) // redevance gare routière par départ
  driverAllowancePerTrip  Float    @default(0) // indemnités fixes par trajet (XOF)
  tollFeesPerTrip         Float    @default(0) // péages fixes par trajet (XOF)
  // Coûts fixes mensuels (proratisés par trajet dans ProfitabilityService)
  driverMonthlySalary     Float // salaire mensuel conducteur assigné (XOF)
  annualInsuranceCost     Float // assurance annuelle (XOF)
  monthlyAgencyFees       Float // frais fixes agence / mois (XOF)
  // Amortissement simplifié
  purchasePrice           Float // prix d'achat (XOF)
  depreciationYears       Int      @default(10)
  residualValue           Float    @default(0)
  // Nombre moyen de trajets par mois (utilisé pour la proratisation des fixes)
  avgTripsPerMonth        Int      @default(30)
  updatedAt               DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  bus    Bus    @relation(fields: [busId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("bus_cost_profiles")
}

// ── Snapshot de rentabilité calculé par trajet (immuable après clôture) ───────
// Généré automatiquement à la transition Trip → COMPLETED.
model TripCostSnapshot {
  id                    String   @id @default(cuid())
  tenantId              String
  tripId                String   @unique
  // ── Coûts variables directs ──────────────────────────────────
  fuelCost              Float
  adBlueCost            Float    @default(0)
  maintenanceCost       Float    @default(0) // km-based (ADR-23)
  stationFee            Float    @default(0)
  tollFees              Float
  driverAllowance       Float
  totalVariableCost     Float
  // ── Coûts fixes proratisés (par trajet) ─────────────────────
  driverDailyCost       Float
  insuranceDailyCost    Float
  agencyDailyCost       Float
  depreciationDaily     Float
  totalFixedCost        Float
  totalCost             Float
  // ── Revenus ─────────────────────────────────────────────────
  ticketRevenue         Float    @default(0)
  parcelRevenue         Float    @default(0)
  totalRevenue          Float    @default(0)
  // ── Marges (ADR-27) ─────────────────────────────────────────
  operationalMargin     Float    @default(0) // revenu - coûts variables
  operationalMarginRate Float    @default(0)
  agencyCommission      Float    @default(0) // commission agence post-snapshot
  netTenantRevenue      Float    @default(0) // totalRevenue - agencyCommission
  netMargin             Float // revenu tenant net - coût total
  marginRate            Float // netMargin / totalCost
  // ── KPIs ────────────────────────────────────────────────────
  bookedSeats           Int
  totalSeats            Int
  fillRate              Float // 0.0 – 1.0
  breakEvenSeats        Int
  profitabilityTag      String // PROFITABLE | BREAK_EVEN | DEFICIT
  computedAt            DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tenantId, profitabilityTag])
  @@index([tenantId, computedAt])
  @@map("trip_cost_snapshots")
}

// ── Statistiques agrégées par route / véhicule / jour ────────────────────────
// Alimentées par un job quotidien (Scheduler) pour le Yield Engine et le dashboard.
model TripAnalytics {
  id        String   @id @default(cuid())
  tenantId  String
  routeId   String
  busId     String
  // Date du trajet (tronquée à minuit UTC pour agrégation journalière)
  tripDate  DateTime
  dayOfWeek Int // 0=Lundi … 6=Dimanche

  avgFillRate      Float
  avgNetMargin     Float
  avgTicketRevenue Float
  avgParcelRevenue Float
  tripCount        Int   @default(1)
  profitableCount  Int   @default(0)
  deficitCount     Int   @default(0)

  // Flags calculés sur fenêtre glissante 12 semaines
  isGoldenDay    Boolean @default(false) // fillRate > 0.85 sur ce jour-de-semaine historiquement
  isBlackRoute   Boolean @default(false) // > 50 % des trajets déficitaires sur les 90 derniers jours
  // Prix de référence moyen (base pour le yield)
  referencePrice Float?

  @@unique([tenantId, routeId, busId, tripDate])
  @@index([tenantId, routeId, isGoldenDay])
  @@index([tenantId, isBlackRoute])
  @@map("trip_analytics")
}

// ═════════════════════════════════════════════════════════════
// SECTION 21 : FLEET DOCUMENTS & CONSUMABLE TRACKING
// ═════════════════════════════════════════════════════════════

// ── Catalogue des types de documents réglementaires (configurable per tenant) ──
// Exemples : Assurance, Carte grise, Contrôle technique, Vignette, Visite médicale…
// alertDaysBeforeExpiry = nombre de jours avant expiry pour déclencher l'alerte.
model VehicleDocumentType {
  id                    String  @id @default(cuid())
  tenantId              String
  name                  String // "Assurance RC" , "Carte grise" …
  code                  String // "INSURANCE" | "REGISTRATION" | etc. (libre)
  alertDaysBeforeExpiry Int     @default(30) // alerte J-30 par défaut
  isMandatory           Boolean @default(true)
  isActive              Boolean @default(true)

  documents VehicleDocument[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("vehicle_document_types")
}

// ── Instance d'un document réglementaire pour un véhicule ────────────────────
// fileKey → MinIO signed URL générée à la demande.
// status calculé par un scheduler : VALID | EXPIRING | EXPIRED | MISSING
model VehicleDocument {
  id           String    @id @default(cuid())
  tenantId     String
  busId        String
  typeId       String
  fileKey      String? // MinIO key (null si document non encore uploadé)
  referenceNo  String? // Numéro de l'assurance, plaque immat…
  issuedAt     DateTime?
  expiresAt    DateTime?
  status       String    @default("MISSING")
  // VALID | EXPIRING | EXPIRED | MISSING
  notes        String?
  uploadedById String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  bus  Bus                 @relation(fields: [busId], references: [id], onDelete: Cascade)
  type VehicleDocumentType @relation(fields: [typeId], references: [id])

  @@index([tenantId, busId])
  @@index([tenantId, status])
  @@index([tenantId, expiresAt])
  @@map("vehicle_documents")
}

// ── Catalogue des consommables par tenant (configurable) ─────────────────────
// nominalLifetimeKm  = durée de vie théorique du consommable (km).
// alertKmBefore      = déclencher l'alerte X km avant la fin de vie.
// Exemples : Pneus (50 000 km, alerte à 5 000 km), Vidange (10 000 km, alerte à 1 000 km)
model ConsumableType {
  id                String  @id @default(cuid())
  tenantId          String
  name              String // "Pneus AV", "Vidange moteur", "Filtres"…
  code              String // "TIRES_FRONT", "OIL_CHANGE"… (libre)
  nominalLifetimeKm Float // durée de vie en km
  alertKmBefore     Float // km avant fin de vie pour alerte
  isActive          Boolean @default(true)

  trackings ConsumableTracking[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("consumable_types")
}

// ── État courant d'un consommable sur un véhicule ────────────────────────────
// Mis à jour à chaque MaintenanceReport impliquant ce consommable.
// Le scheduler compare currentKm vs (lastReplacedKm + nominalLifetimeKm - alertKmBefore)
// pour publier un événement fleet.consumable.alert_due.
model ConsumableTracking {
  id             String    @id @default(cuid())
  tenantId       String
  busId          String
  typeId         String
  lastReplacedKm Float? // kilométrage au dernier remplacement (null = jamais remplacé)
  lastReplacedAt DateTime?
  currentKm      Float     @default(0) // kilométrage actuel du bus (synchronisé depuis GPS/TripEvent)
  status         String    @default("OK")
  // OK | ALERT | OVERDUE
  nextDueKm      Float? // calculé : lastReplacedKm + nominalLifetimeKm
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  bus  Bus            @relation(fields: [busId], references: [id], onDelete: Cascade)
  type ConsumableType @relation(fields: [typeId], references: [id])

  @@unique([busId, typeId])
  @@index([tenantId, status])
  @@map("consumable_trackings")
}

// ── Intervenant sur un rapport de maintenance ─────────────────────────────────
// Trace qui a fait quoi : mécanicien, nettoyeur, contrôleur technique…
model MaintenanceIntervenant {
  id           String   @id @default(cuid())
  tenantId     String
  reportId     String
  staffId      String? // Staff.id si interne (null si prestataire externe)
  externalName String? // Nom si prestataire externe
  role         String // "MECHANIC" | "CLEANER" | "TECHNICAL_INSPECTOR" | … (libre)
  hoursWorked  Float?
  notes        String?
  createdAt    DateTime @default(now())

  report MaintenanceReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([tenantId])
  @@map("maintenance_intervenants")
}

// ── Pièce / consommable remplacé dans un rapport de maintenance ────────────────
// Remplace l'ancien champ partsUsed Json pour permettre des requêtes structurées.
model MaintenancePart {
  id               String   @id @default(cuid())
  tenantId         String
  reportId         String
  consumableTypeId String? // null si pièce ad-hoc non cataloguée
  partName         String // Nom libre (ex: "Filtre à huile Mann W 719/30")
  partReference    String? // Référence constructeur
  quantity         Float    @default(1)
  unitCostXaf      Float?
  kmAtReplacement  Float? // km du bus au moment du remplacement
  createdAt        DateTime @default(now())

  report MaintenanceReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([tenantId])
  @@map("maintenance_parts")
}

// ═════════════════════════════════════════════════════════════
// SECTION 22 : DRIVER PROFILE & RH
// ═════════════════════════════════════════════════════════════

// ── Configuration des temps de repos réglementaires (par tenant) ──────────────
// minRestMinutes          = repos minimum obligatoire entre deux services (défaut 11h).
// maxDrivingMinutesPerDay = conduite max par période de 24h.
// maxDrivingMinutesPerWeek= conduite max sur 7 jours glissants.
// Ces valeurs sont chargées par le SchedulingGuardService avant toute assignation.
model DriverRestConfig {
  id                       String @id @default(cuid())
  tenantId                 String @unique
  minRestMinutes           Int    @default(660) // 11h = 660 min
  maxDrivingMinutesPerDay  Int    @default(540) // 9h = 540 min
  maxDrivingMinutesPerWeek Int    @default(3360) // 56h = 3360 min
  alertBeforeEndRestMin    Int    @default(30) // prévenir 30 min avant fin repos autorisé

  @@map("driver_rest_configs")
}

// ── Période de repos déclarée pour un chauffeur ───────────────────────────────
// Créée automatiquement à la fin de chaque trajet (side effect trip.completed).
// Peut aussi être créée manuellement (suspension médicale, etc.).
model DriverRestPeriod {
  id        String    @id @default(cuid())
  tenantId  String
  staffId   String
  startedAt DateTime
  endedAt   DateTime?
  source    String // AUTO | MANUAL | MEDICAL
  notes     String?
  createdAt DateTime  @default(now())

  @@index([tenantId, staffId, endedAt])
  @@map("driver_rest_periods")
}

// ── Permis de conduire chauffeur (remplace licenseData Json dans Staff) ───────
// Un chauffeur peut avoir plusieurs catégories (B, D, EC…).
// La colonne Staff.licenseData est conservée pour rétro-compatibilité.
model DriverLicense {
  id           String   @id @default(cuid())
  tenantId     String
  staffId      String
  category     String // "B" | "D" | "EC" | … (libre)
  licenseNo    String
  issuedAt     DateTime
  expiresAt    DateTime
  issuingState String? // Pays ou état émetteur
  fileKey      String? // Scan du permis — MinIO key
  status       String   @default("VALID")
  // VALID | EXPIRING | EXPIRED | SUSPENDED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, staffId, category])
  @@index([tenantId, staffId])
  @@index([tenantId, expiresAt])
  @@index([tenantId, status])
  @@map("driver_licenses")
}

// ── Catalogue des types de formation obligatoire (par tenant) ─────────────────
// frequencyDays = récurrence obligatoire en jours (ex: premiers secours tous les 365j).
model DriverTrainingType {
  id            String  @id @default(cuid())
  tenantId      String
  name          String // "Premiers secours", "Conduite défensive"…
  code          String // "FIRST_AID", "DEFENSIVE_DRIVING"… (libre)
  frequencyDays Int     @default(365) // récurrence annuelle par défaut
  durationHours Float   @default(8)
  isMandatory   Boolean @default(true)
  isActive      Boolean @default(true)

  trainings DriverTraining[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("driver_training_types")
}

// ── Planning de formation par chauffeur ──────────────────────────────────────
// Généré automatiquement par le scheduler (tous les frequencyDays depuis la dernière completion).
model DriverTraining {
  id           String    @id @default(cuid())
  tenantId     String
  staffId      String
  typeId       String
  scheduledAt  DateTime
  completedAt  DateTime?
  status       String    @default("PLANNED")
  // PLANNED | COMPLETED | MISSED | CANCELLED
  trainerName  String?
  locationName String?
  fileKey      String? // Attestation MinIO
  notes        String?
  createdAt    DateTime  @default(now())

  type DriverTrainingType @relation(fields: [typeId], references: [id])

  @@index([tenantId, staffId])
  @@index([tenantId, status])
  @@index([tenantId, scheduledAt])
  @@map("driver_trainings")
}

// ── Règles de remédiation CRM (par tenant) ───────────────────────────────────
// Si le score CRM d'un chauffeur descend sous scoreBelowThreshold,
// le système génère automatiquement une DriverRemediationAction de type actionType.
model DriverRemediationRule {
  id                  String  @id @default(cuid())
  tenantId            String
  name                String
  scoreBelowThreshold Float // ex: 3.5 sur 5
  actionType          String // "TRAINING" | "WARNING" | "SUSPENSION" (libre)
  trainingTypeId      String? // si actionType = TRAINING, quelle formation déclencher
  suspensionDays      Int? // si actionType = SUSPENSION, durée
  priority            Int     @default(0) // ordre d'évaluation des règles
  isActive            Boolean @default(true)

  actions DriverRemediationAction[]

  @@index([tenantId])
  @@map("driver_remediation_rules")
}

// ── Action de remédiation déclenchée pour un chauffeur ───────────────────────
model DriverRemediationAction {
  id             String    @id @default(cuid())
  tenantId       String
  staffId        String
  ruleId         String
  scoreAtTrigger Float // score au moment du déclenchement
  status         String    @default("PENDING")
  // PENDING | IN_PROGRESS | COMPLETED | CANCELLED
  triggeredAt    DateTime  @default(now())
  dueAt          DateTime?
  completedAt    DateTime?
  notes          String?

  rule DriverRemediationRule @relation(fields: [ruleId], references: [id])

  @@index([tenantId, staffId])
  @@index([tenantId, status])
  @@map("driver_remediation_actions")
}

// ═════════════════════════════════════════════════════════════
// SECTION 23 : CREW BRIEFING (extension CrewAssignment)
// ═════════════════════════════════════════════════════════════

// ── Catalogue des équipements de sécurité obligatoires (par tenant) ───────────
// Exemples : Gilets, Lampes torches, Trousse de secours, Cales, Sangles, Triangles, Cric
model BriefingEquipmentType {
  id          String  @id @default(cuid())
  tenantId    String
  name        String // "Gilets de sécurité"
  code        String // "SAFETY_VESTS" (libre)
  requiredQty Int     @default(1)
  isMandatory Boolean @default(true)
  isActive    Boolean @default(true)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("briefing_equipment_types")
}

// ── Enregistrement de briefing pour un CrewAssignment ────────────────────────
// Un CrewBriefingRecord est créé lors du briefing pré-départ.
// checkedItems = JSON : [{ equipmentTypeId, qty, ok, notes }]
// allEquipmentOk = computed field : true si tous les items mandatory sont OK.
model CrewBriefingRecord {
  id             String   @id @default(cuid())
  tenantId       String
  assignmentId   String   @unique
  conductedById  String // Staff.id du responsable de briefing (driver ou co-pilot)
  checkedItems   Json     @default("[]")
  // [{ equipmentTypeId: string, qty: number, ok: boolean, notes?: string }]
  allEquipmentOk Boolean  @default(false)
  briefingNotes  String?
  gpsLat         Float? // position GPS au moment du briefing
  gpsLng         Float?
  completedAt    DateTime @default(now())
  createdAt      DateTime @default(now())

  assignment CrewAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("crew_briefing_records")
}

// ═════════════════════════════════════════════════════════════
// SECTION 24 : QHSE — ACCIDENTS & LITIGES
// ═════════════════════════════════════════════════════════════

// ── Catalogue de sévérité d'accident (par tenant) ────────────────────────────
// Exemples : Léger (0 blessé grave), Lourd (blessé grave), Mortel (décès)
// Les codes sont libres pour s'adapter à la réglementation locale.
model AccidentSeverityType {
  id              String  @id @default(cuid())
  tenantId        String
  name            String // "Accident léger", "Accident grave"…
  code            String // "MINOR" | "SERIOUS" | "FATAL" (libre)
  color           String  @default("#f59e0b") // couleur dashboard
  requiresQhse    Boolean @default(false) // déclenche alerte QHSE automatique
  requiresPolice  Boolean @default(false) // déclenche consigne "Appeler la police"
  requiresInsurer Boolean @default(false) // déclenche contact assureur obligatoire
  sortOrder       Int     @default(0)
  isActive        Boolean @default(true)

  accidents AccidentReport[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("accident_severity_types")
}

// ── Rapport d'accident principal ─────────────────────────────────────────────
// Créé par le chauffeur, co-pilote ou agent QHSE depuis leurs apps respectives.
// Peut déclencher un workflow QHSE (QhseProcedureExecution).
model AccidentReport {
  id             String    @id @default(cuid())
  tenantId       String
  incidentId     String?   @unique // FK vers Incident existant (si venu du système incident)
  tripId         String?
  busId          String?
  severityTypeId String
  reportedById   String // Staff.id (driver/crew) ou User.id (QHSE agent)
  reportedByRole String // "DRIVER" | "CREW" | "QHSE" | "STATION_AGENT"
  occurredAt     DateTime
  gpsLat         Float?
  gpsLng         Float?
  locationDesc   String?
  description    String    @db.Text
  circumstance   String?   @db.Text // description circonstances (route, météo, tiers…)
  photoKeys      Json      @default("[]") // string[] clés MinIO photos
  status         String    @default("OPEN")
  // OPEN | UNDER_INVESTIGATION | LEGAL | SETTLED | CLOSED
  assignedQhseId String? // QHSE responsible assigned
  closedAt       DateTime?
  closedById     String?
  closingNotes   String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  severityType    AccidentSeverityType     @relation(fields: [severityTypeId], references: [id])
  thirdParties    AccidentThirdParty[]
  injuries        AccidentInjury[]
  disputeTracking DisputeTracking?
  procedureExecs  QhseProcedureExecution[]

  @@index([tenantId, status])
  @@index([tenantId, occurredAt])
  @@index([tenantId, busId])
  @@map("accident_reports")
}

// ── Tiers impliqués dans un accident ─────────────────────────────────────────
model AccidentThirdParty {
  id            String   @id @default(cuid())
  tenantId      String
  reportId      String
  type          String // "VEHICLE" | "PEDESTRIAN" | "PROPERTY" | "OTHER" (libre)
  name          String?
  phone         String?
  plateNumber   String? // si véhicule
  vehicleModel  String?
  insuranceRef  String? // numéro d'assurance tiers
  statementFile String? // MinIO — constat amiable signé
  notes         String?
  createdAt     DateTime @default(now())

  report AccidentReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([tenantId])
  @@map("accident_third_parties")
}

// ── Blessures enregistrées dans l'accident ───────────────────────────────────
model AccidentInjury {
  id           String    @id @default(cuid())
  tenantId     String
  reportId     String
  personType   String // "PASSENGER" | "DRIVER" | "CREW" | "PEDESTRIAN" | "THIRD_PARTY"
  personName   String?
  ticketId     String? // FK Ticket si c'est un passager
  severity     String // "MINOR" | "SERIOUS" | "CRITICAL" | "FATAL" (libre)
  hospitalId   String? // FK Hospital si transfert hospitalier
  hospitalName String? // Nom libre si hôpital non répertorié
  admittedAt   DateTime?
  dischargedAt DateTime?
  medicalNotes String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  report    AccidentReport    @relation(fields: [reportId], references: [id], onDelete: Cascade)
  hospital  Hospital?         @relation(fields: [hospitalId], references: [id])
  followUps MedicalFollowUp[]

  @@index([reportId])
  @@index([tenantId])
  @@map("accident_injuries")
}

// ── Hôpitaux référencés (par tenant) ─────────────────────────────────────────
model Hospital {
  id       String  @id @default(cuid())
  tenantId String
  name     String
  city     String
  address  String?
  phone    String?
  gpsLat   Float?
  gpsLng   Float?
  isActive Boolean @default(true)

  injuries AccidentInjury[]

  @@index([tenantId, city])
  @@map("hospitals")
}

// ── Suivi médical d'une blessure ─────────────────────────────────────────────
model MedicalFollowUp {
  id               String    @id @default(cuid())
  tenantId         String
  injuryId         String
  date             DateTime
  practitionerName String?
  notes            String?   @db.Text
  nextAppointment  DateTime?
  fileKey          String? // Compte-rendu médical MinIO
  createdAt        DateTime  @default(now())

  injury AccidentInjury @relation(fields: [injuryId], references: [id], onDelete: Cascade)

  @@index([injuryId])
  @@map("medical_followups")
}

// ── Suivi du litige (assurance ou gré à gré) ────────────────────────────────
model DisputeTracking {
  id              String    @id @default(cuid())
  tenantId        String
  reportId        String    @unique
  mode            String    @default("INSURANCE")
  // "INSURANCE" | "AMICABLE" | "LEGAL"
  insurerRef      String? // Numéro de dossier assureur
  insurerName     String?
  adjusterId      String? // Nom de l'expert mandaté
  status          String    @default("OPEN")
  // OPEN | PENDING_ADJUSTER | NEGOTIATION | AGREED | CLOSED | CONTESTED
  estimatedTotal  Float? // Estimation du sinistre total
  advancedAmount  Float     @default(0) // Montant pré-financé par l'entreprise
  finalSettlement Float? // Montant final agréé
  settledAt       DateTime?
  closingNotes    String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  report   AccidentReport   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  expenses DisputeExpense[]

  @@index([tenantId, status])
  @@map("dispute_trackings")
}

// ── Frais individuels liés au litige ────────────────────────────────────────
model DisputeExpense {
  id           String    @id @default(cuid())
  tenantId     String
  disputeId    String
  type         String // "REPAIR" | "MEDICAL" | "LEGAL" | "TOWING" | "OTHER" (libre)
  description  String
  amountXaf    Float
  paidAt       DateTime?
  fileKey      String? // Justificatif MinIO
  approvedById String?
  createdAt    DateTime  @default(now())

  dispute DisputeTracking @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId])
  @@index([tenantId])
  @@map("dispute_expenses")
}

// ── Procédures QHSE configurables par tenant ────────────────────────────────
// Une procédure est associée à un type de déclencheur (ex: ACCIDENT_FATAL).
// Le code du trigger est libre pour s'adapter à la réglementation locale.
model QhseProcedure {
  id          String  @id @default(cuid())
  tenantId    String
  name        String
  triggerCode String // "ACCIDENT_FATAL" | "ACCIDENT_SERIOUS" | "FIRE" | "BREAKDOWN" (libre)
  description String?
  isActive    Boolean @default(true)
  version     Int     @default(1)

  steps      QhseProcedureStep[]
  executions QhseProcedureExecution[]

  @@unique([tenantId, triggerCode, version])
  @@index([tenantId])
  @@map("qhse_procedures")
}

// ── Étapes d'une procédure QHSE ──────────────────────────────────────────────
model QhseProcedureStep {
  id              String  @id @default(cuid())
  procedureId     String
  order           Int
  description     String  @db.Text
  responsible     String // "DRIVER" | "CREW" | "QHSE" | "STATION_AGENT" (libre)
  isVerification  Boolean @default(false) // si true, l'exécutant doit cocher OK
  isPhotoRequired Boolean @default(false)

  procedure QhseProcedure       @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  stepExecs QhseStepExecution[]

  @@unique([procedureId, order])
  @@map("qhse_procedure_steps")
}

// ── Exécution d'une procédure (1 par accident / trigger) ─────────────────────
model QhseProcedureExecution {
  id          String    @id @default(cuid())
  tenantId    String
  reportId    String
  procedureId String
  startedById String // qui a lancé la procédure
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  status      String    @default("IN_PROGRESS")
  // IN_PROGRESS | COMPLETED | ABORTED

  report    AccidentReport      @relation(fields: [reportId], references: [id], onDelete: Cascade)
  procedure QhseProcedure       @relation(fields: [procedureId], references: [id])
  stepExecs QhseStepExecution[]

  @@index([tenantId, reportId])
  @@map("qhse_procedure_executions")
}

// ── Exécution d'une étape individuelle ───────────────────────────────────────
model QhseStepExecution {
  id           String   @id @default(cuid())
  executionId  String
  stepId       String
  executedById String
  executedAt   DateTime @default(now())
  isOk         Boolean  @default(true)
  notes        String?
  photoKey     String? // MinIO si isPhotoRequired

  execution QhseProcedureExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  step      QhseProcedureStep      @relation(fields: [stepId], references: [id])

  @@unique([executionId, stepId])
  @@map("qhse_step_executions")
}

// ─────────────────────────────────────────────────────────────
// SECTION 21 : ATTACHMENTS POLYMORPHES (Documents génériques)
// ─────────────────────────────────────────────────────────────

model Attachment {
  id         String   @id @default(cuid())
  tenantId   String
  entityType String // CUSTOMER | STAFF | VEHICLE | TRIP | INCIDENT | PARCEL...
  entityId   String
  kind       String // CONTRACT | ID_CARD | LICENSE | CERTIFICATE | PHOTO | OTHER
  fileName   String
  mimeType   String
  size       Int
  storageKey String // MinIO key
  checksum   String? // SHA-256
  uploadedBy String? // userId
  createdAt  DateTime @default(now())

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, kind])
  @@map("attachments")
}

// ─────────────────────────────────────────────────────────────
// SECTION : PORTAIL PUBLIC VOYAGEUR
// ─────────────────────────────────────────────────────────────

// ── Configuration du portail public par tenant ───────────────────────────────
// Stocke les réglages propres au portail voyageur : sections activées, hero,
// slogan multilingue, réseaux sociaux, moyens de paiement par pays.
model TenantPortalConfig {
  id       String @id @default(cuid())
  tenantId String @unique

  // Thème visuel du portail (amber-luxury | ocean-blue | emerald-nature)
  themeId String @default("amber-luxury")

  // Sections activées (le booking est toujours ON)
  showAbout   Boolean @default(true)
  showFleet   Boolean @default(true)
  showNews    Boolean @default(true)
  showContact Boolean @default(true)

  // Module CMS actualités (activable/désactivable)
  newsCmsEnabled Boolean @default(false)

  // Hero visuel
  heroImageUrl String? // URL MinIO de l'image hero (haute résolution)
  heroOverlay  Float   @default(0.4) // opacité overlay sombre sur le hero (0–1)

  // Slogan multilingue — JSON { fr: "...", en: "...", ... }
  slogans Json @default("{}")

  // Réseaux sociaux — JSON { facebook?: url, twitter?: url, instagram?: url, ... }
  socialLinks Json @default("{}")

  // SEO additionnels
  ogImageUrl String? // Open Graph image

  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_portal_configs")
}

// ── Pages CMS légères par tenant ─────────────────────────────────────────────
// Contenu "à propos", mentions légales, conditions de vente…
// HTML sanitisé côté service (éditeur riche frontend).
model TenantPage {
  id       String @id @default(cuid())
  tenantId String

  slug         String // about | terms | privacy | news | custom-*
  title        String
  content      String  @db.Text // HTML sanitisé
  locale       String  @default("fr") // ISO 639-1
  sortOrder    Int     @default(0)
  published    Boolean @default(false)
  showInFooter Boolean @default(false) // Affiché dans le footer du portail uniquement

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug, locale])
  @@index([tenantId, published])
  @@map("tenant_pages")
}

// ── Actualités / blog par tenant ─────────────────────────────────────────────
model TenantPost {
  id       String @id @default(cuid())
  tenantId String

  title       String
  slug        String? // URL-friendly slug (auto-generated from title)
  excerpt     String?   @db.VarChar(500)
  content     String    @db.Text // HTML sanitisé (éditeur riche)
  coverImage  String? // URL MinIO
  locale      String    @default("fr")
  published   Boolean   @default(false)
  publishedAt DateTime?
  authorName  String?
  tags        String[]  @default([]) // Tags libres pour filtrage

  media     PostMedia[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId, published, publishedAt])
  @@map("tenant_posts")
}

// ── Médias attachés à un post (photos / vidéos) ─────────────────────────────
model PostMedia {
  id     String @id @default(cuid())
  postId String

  url       String // Clé MinIO (signée à la lecture)
  type      String // IMAGE | VIDEO
  caption   String?
  sortOrder Int     @default(0)

  createdAt DateTime   @default(now())
  post      TenantPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, sortOrder])
  @@map("post_media")
}

// ─────────────────────────────────────────────────────────────
// SECTION 27 : TARIFICATION — Grille tarifaire & Promotions
// ─────────────────────────────────────────────────────────────

// ── Grille tarifaire par route (surcharge classe / type / période) ──────────
// Complémentaire à PricingRules (prix de base) : applique des modificateurs
// en fonction de la classe (STANDARD/CONFORT/VIP), du type de trajet,
// ou de créneaux horaires (heures de pointe, week-end, jours fériés).
model TariffGrid {
  id         String    @id @default(cuid())
  tenantId   String
  routeId    String
  name       String // "Tarif Haute Saison", "Tarif Nuit"
  // Classe véhicule ciblée (null = toutes classes)
  busType    String? // STANDARD | CONFORT | VIP | MINIBUS (null = all)
  // Modificateur : multiplicateur (1.0 = pas de changement, 1.2 = +20%)
  multiplier Float     @default(1.0)
  // Ou : prix fixe (prend la priorité sur multiplier si > 0)
  fixedPrice Float?
  // Plage horaire (optionnelle)
  startHour  Int? // 0–23
  endHour    Int? // 0–23
  // Jours de semaine (bitmask : 1=Lun, 2=Mar, 4=Mer, 8=Jeu, 16=Ven, 32=Sam, 64=Dim)
  dayMask    Int       @default(127) // 127 = tous les jours
  // Période de validité
  validFrom  DateTime?
  validTo    DateTime?
  isActive   Boolean   @default(true)
  priority   Int       @default(0) // plus élevé = appliqué en priorité
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  route  Route  @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, routeId, isActive])
  @@map("tariff_grids")
}

// ── Promotions (réductions, codes promo, campagnes) ─────────────────────────
// Applicable sur une route, une classe, ou globale (routeId null).
model Promotion {
  id            String   @id @default(cuid())
  tenantId      String
  code          String // Code promo (ex: "NOEL2026", "EARLYBIRD")
  name          String // Nom d'affichage
  description   String?
  // Type de réduction
  discountType  String // PERCENTAGE | FIXED_AMOUNT
  discountValue Float // ex: 10 (= 10% ou 10 XAF selon le type)
  // Limites
  maxUses       Int? // Nombre max d'utilisations (null = illimité)
  usedCount     Int      @default(0)
  maxPerUser    Int      @default(1) // Utilisation max par client
  minAmount     Float? // Montant minimum de commande requis
  // Ciblage
  routeId       String? // Null = toutes routes
  busType       String? // Null = toutes classes
  // Période de validité
  validFrom     DateTime
  validTo       DateTime
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@index([tenantId, validFrom, validTo])
  @@map("promotions")
}

// ─────────────────────────────────────────────────────────────
// SECTION 28 : FACTURATION
// ─────────────────────────────────────────────────────────────

// ── Factures émises (billets, colis, abonnements, corporate) ────────────────
model Invoice {
  id            String    @id @default(cuid())
  tenantId      String
  invoiceNumber String // Numéro séquentiel par tenant (ex: "INV-2026-00042")
  // Client
  customerName  String
  customerEmail String?
  customerPhone String?
  customerId    String? // userId si client enregistré
  // Montants
  subtotal      Float // Total HT
  taxRate       Float     @default(0) // TVA / taxe locale (fraction, ex: 0.18 = 18%)
  taxAmount     Float     @default(0) // Montant taxe calculé
  totalAmount   Float // TTC
  currency      String    @default("XAF")
  // Références
  entityType    String // TICKET | PARCEL | SUBSCRIPTION | CORPORATE
  entityId      String? // ticketId, parcelId…
  // Statut
  status        String    @default("DRAFT")
  // DRAFT | ISSUED | PAID | CANCELLED | REFUNDED
  issuedAt      DateTime?
  paidAt        DateTime?
  dueDate       DateTime?
  // Paiement
  paymentMethod String? // CASH | MOBILE_MONEY | CARD
  paymentRef    String? // Référence externe paiement
  // Metadata / lignes
  lineItems     Json      @default("[]")
  // [{ description, quantity, unitPrice, total }]
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, status])
  @@index([tenantId, issuedAt])
  @@index([tenantId, customerId])
  @@map("invoices")
}

// ─────────────────────────────────────────────────────────────
// SECTION 29 : AFFICHAGE GARE — Quais & Annonces
// ─────────────────────────────────────────────────────────────

// ── Quais / Plateformes de gare ─────────────────────────────────────────────
// Un quai est une zone physique d'embarquement dans une station.
model Platform {
  id            String   @id @default(cuid())
  tenantId      String
  stationId     String
  name          String // "Quai A", "Quai 1", "Zone VIP"
  code          String // "A", "1", "VIP" — identifiant court affiché
  capacity      Int      @default(1) // Nombre de bus simultanés
  status        String   @default("AVAILABLE")
  // AVAILABLE | OCCUPIED | MAINTENANCE | CLOSED
  // Bus actuellement affecté (null si libre)
  currentTripId String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  station Station @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@unique([tenantId, stationId, code])
  @@index([tenantId, stationId])
  @@index([tenantId, status])
  @@map("platforms")
}

// ── Annonces gare (sonores / visuelles) ──────────────────────────────────────
// Messages diffusés sur les écrans et haut-parleurs d'une station.
model Announcement {
  id          String    @id @default(cuid())
  tenantId    String
  stationId   String? // Null = diffusé sur toutes les stations du tenant
  // Contenu
  title       String
  message     String
  type        String    @default("INFO")
  // INFO | DELAY | CANCELLATION | SECURITY | PROMO | CUSTOM
  priority    Int       @default(0) // plus élevé = affiché en premier
  // Diffusion
  isActive    Boolean   @default(true)
  startsAt    DateTime  @default(now())
  endsAt      DateTime?
  // Auteur
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  station Station? @relation(fields: [stationId], references: [id])

  @@index([tenantId, isActive])
  @@index([tenantId, stationId, isActive])
  @@map("announcements")
}

// ── Moyens de paiement par pays ──────────────────────────────────────────────
// Table de référence : quels moyens de paiement sont disponibles par pays.
// Le tenant hérite des méthodes de son `country` (ISO 3166-1 alpha-2).
model PaymentMethodConfig {
  id          String @id @default(cuid())
  countryCode String // ISO 3166-1 alpha-2 (CG, SN, CD, CM, CI…)

  // Identifiant interne du provider (mtn_momo, airtel_money, orange_money, wave, card_visa, card_mastercard…)
  providerId  String
  // Nom d'affichage
  displayName String
  // Type : MOBILE_MONEY | CARD | BANK_TRANSFER
  type        String
  // Logo URL (CDN/MinIO)
  logoUrl     String?
  // Indicatif téléphonique par défaut pour ce provider dans ce pays
  phonePrefix String? // ex: "+242", "+243"
  // Ordre d'affichage (plus petit = plus haut)
  sortOrder   Int     @default(0)
  // Actif ou non
  enabled     Boolean @default(true)

  @@unique([countryCode, providerId])
  @@index([countryCode, enabled])
  @@map("payment_method_configs")
}

// ─────────────────────────────────────────────────────────────
// SECTION 30 : PORTAIL PLATEFORME SaaS — Plans, Billing, Support, Analytics
// ─────────────────────────────────────────────────────────────
//
// Ces modèles sont gérés uniquement par les agents du tenant plateforme
// (SUPER_ADMIN / SUPPORT_L1 / SUPPORT_L2). Aucun hardcoding de plan :
// les SA créent/éditent/retirent les plans et les modules associés depuis
// l'interface d'administration ; les tenants clients choisissent dans le
// catalogue disponible.

// ── Plan SaaS (catalogue proposé aux tenants) ────────────────────────────────
// Un plan agrège un prix, une devise, un cycle de facturation et un ensemble
// de moduleKeys activables. Pas de contrainte dure côté DB (le tenant peut
// souscrire n'importe quel plan actif) — la logique métier vit dans le service.
model Plan {
  id           String   @id @default(cuid())
  slug         String   @unique // identifiant stable ("starter", "pro"…)
  name         String // affichage
  description  String?
  price        Float    @default(0) // montant facturé par cycle (0 = gratuit/trial)
  currency     String   @default("EUR")
  billingCycle String   @default("MONTHLY") // MONTHLY | YEARLY | ONE_SHOT | CUSTOM
  trialDays    Int      @default(0)
  // Limites et quotas (soft — informatif UI, le backend applique ce qui est
  // nécessaire via QuotaManager). Structure libre : { maxUsers: 50, maxAgencies: 5, … }
  limits       Json     @default("{}")
  // SLA affiché au client (ex: { firstResponseMin: 60, uptimePct: 99.5 })
  sla          Json     @default("{}")
  // Ordre d'affichage dans le catalogue (petit = haut)
  sortOrder    Int      @default(0)
  // isPublic : visible dans le catalogue tenant. Si false, invitation-only.
  isPublic     Boolean  @default(true)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  modules       PlanModule[]
  tenants       Tenant[]
  subscriptions PlatformSubscription[]

  @@index([isActive, isPublic, sortOrder])
  @@map("plans")
}

// ── Module inclus dans un plan (M2M Plan × moduleKey) ────────────────────────
// moduleKey référence une clé InstalledModule.moduleKey — pas de FK pour
// permettre aux SA d'ajouter des modules nouveaux sans migration.
model PlanModule {
  id        String @id @default(cuid())
  planId    String
  moduleKey String

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, moduleKey])
  @@index([planId])
  @@map("plan_modules")
}

// ── Souscription d'un tenant à un plan ───────────────────────────────────────
// 1:1 avec Tenant (un tenant a au plus une souscription active).
// L'historique des changements de plan vit dans AuditLog.
model PlatformSubscription {
  id                 String    @id @default(cuid())
  tenantId           String    @unique
  planId             String
  status             String    @default("TRIAL") // TRIAL | ACTIVE | PAST_DUE | SUSPENDED | CANCELLED
  startedAt          DateTime  @default(now())
  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  renewsAt           DateTime?
  cancelledAt        DateTime?
  cancelReason       String?
  // Si true, le renewal cron tente un prélèvement automatique avec la dernière
  // méthode de paiement utilisée (SubscriptionRenewalService). Si le PSP exige
  // une nouvelle saisie (carte non tokenisée), l'auto-renew dégrade vers un
  // email de rappel avec lien de checkout. Défaut false — l'admin doit activer
  // explicitement via /admin/billing.
  autoRenew          Boolean   @default(false)
  // Première entrée en PAST_DUE — point de départ des rappels dunning J+1/J+3/J+7.
  // Remis à null quand la subscription repasse ACTIVE.
  pastDueSince       DateTime?
  // meta free-form : ID Stripe/PayPal + refs du dernier paiement réussi pour
  // l'auto-renew :
  //   {
  //     lastIntentId:          string,
  //     lastMethod:            'CARD'|'MOBILE_MONEY'|...,
  //     lastCustomerRef:       string,   // ID client côté PSP si fourni
  //     lastAttemptExternalRef:string,   // ID transaction PSP
  //     lastSuccessAt:         ISO-date,
  //     dunningSent:           { day1: ISO, day3: ISO, day7: ISO }
  //   }
  externalRefs       Json      @default("{}")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant   Tenant            @relation(fields: [tenantId], references: [id])
  plan     Plan              @relation(fields: [planId], references: [id])
  invoices PlatformInvoice[]

  @@index([status])
  @@index([renewsAt])
  @@map("platform_subscriptions")
}

// ── Facture plateforme → tenant ──────────────────────────────────────────────
// Distinct de `Invoice` (qui est tenant→client final). Scopée tenant plateforme.
model PlatformInvoice {
  id             String    @id @default(cuid())
  subscriptionId String
  tenantId       String
  invoiceNumber  String    @unique // ex: "TRANSLOG-2026-00042"
  periodStart    DateTime
  periodEnd      DateTime
  subtotal       Float
  taxRate        Float     @default(0)
  taxAmount      Float     @default(0)
  totalAmount    Float
  currency       String    @default("EUR")
  status         String    @default("DRAFT") // DRAFT | ISSUED | PAID | VOID | OVERDUE
  issuedAt       DateTime?
  dueAt          DateTime?
  paidAt         DateTime?
  paymentMethod  String?
  paymentRef     String?
  lineItems      Json      @default("[]")
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  subscription PlatformSubscription @relation(fields: [subscriptionId], references: [id])
  tenant       Tenant               @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
  @@index([status, dueAt])
  @@map("platform_invoices")
}

// ── Support ticket (tenant ↔ plateforme) ─────────────────────────────────────
// Un ticket est ouvert par un user d'un tenant client et atterrit dans la
// queue du support plateforme. Les agents L1/L2/SA y répondent via
// SupportMessage.
model SupportTicket {
  id                       String    @id @default(cuid())
  tenantId                 String // tenant émetteur
  reporterUserId           String // user du tenant qui a ouvert
  title                    String
  description              String
  category                 String    @default("OTHER") // BUG | QUESTION | FEATURE_REQUEST | INCIDENT | BILLING | OTHER
  priority                 String    @default("NORMAL") // LOW | NORMAL | HIGH | CRITICAL
  status                   String    @default("OPEN") // OPEN | IN_PROGRESS | WAITING_CUSTOMER | RESOLVED | CLOSED
  assignedToPlatformUserId String? // null = queue non assignée
  firstResponseAt          DateTime?
  resolvedAt               DateTime?
  closedAt                 DateTime?
  slaDueAt                 DateTime? // calculé depuis plan.sla + priority
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  messages SupportMessage[]

  @@index([tenantId, status])
  @@index([status, priority, createdAt])
  @@index([assignedToPlatformUserId, status])
  @@map("support_tickets")
}

model SupportMessage {
  id          String   @id @default(cuid())
  ticketId    String
  authorId    String // userId (tenant OU plateforme)
  authorScope String // TENANT | PLATFORM — source de vérité UX
  body        String
  // attachments : [{ url, filename, mime, size }] via MinIO
  attachments Json     @default("[]")
  isInternal  Boolean  @default(false) // note privée plateforme (pas visible au tenant)
  createdAt   DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@map("support_messages")
}

// ── Agrégats analytics (alimentés par cron nocturne) ─────────────────────────
// DailyActiveUser : 1 ligne par (tenant, user, date). Source de DAU/MAU
// agrégés dans les endpoints /platform/analytics/*.
model DailyActiveUser {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String
  date          DateTime @db.Date // jour (00:00 UTC)
  sessionsCount Int      @default(1)
  createdAt     DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([userId, date])
  @@index([tenantId, date])
  @@index([date])
  @@map("daily_active_users")
}

// TenantHealthScore : 1 ligne par (tenant, date). Score agrégé 0-100 +
// détail des composantes (uptime, incidents, refunds, support, dlq…).
model TenantHealthScore {
  id         String   @id @default(cuid())
  tenantId   String
  date       DateTime @db.Date
  score      Int // 0-100
  // components : { uptime: 0.99, incidents: 2, refundRate: 0.01, supportResponseMin: 45, dlqCount: 0 }
  components Json     @default("{}")
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, date])
  @@index([date, score])
  @@map("tenant_health_scores")
}

// ── Configuration plateforme (KV store global, DB-driven) ───────────────────
// Source de vérité pour les seuils et paramètres plateforme qui ne vivent pas
// sur un plan spécifique. Édités depuis l'UI Settings plateforme par le SA
// sans redéploiement. Toujours un fallback hardcodé côté service si la clé
// est absente ou si la DB est indisponible — pas de panique.
//
// Conventions de clés (namespacées, pas d'enum pour rester extensible) :
//   - "health.riskThreshold"              (number 0-100)
//   - "health.thresholds.incidents"       (number)
//   - "health.thresholds.tickets"         (number)
//   - "health.thresholds.dlqEvents"       (number)
//   - "billing.defaultInvoiceDueDays"     (number)
//   - "billing.defaultCustomCycleDays"    (number)
model PlatformConfig {
  key       String   @id
  value     Json
  updatedBy String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("platform_config")
}

// ═════════════════════════════════════════════════════════════════════════════
// SECTION 31 : PAIEMENTS & FISCALITÉ — Domaine canonique multi-provider
// ═════════════════════════════════════════════════════════════════════════════
//
// Architecture (hexagonale) :
//   PaymentIntent (1)   ── entité canonique d'un achat (unique par transaction métier)
//     └─ PaymentAttempt (N)   ── chaque tentative auprès d'un provider (retry, switch)
//           └─ PaymentEvent (N)  ── journal append-only (webhook, statut, refund)
//
// Toutes les valeurs numériques (limites, timings, taux, devises) proviennent
// de TenantPaymentConfig / TenantTax / PaymentProviderState / PlatformConfig.
// AUCUNE constante littérale dans le code métier — règle d'or du projet.
//
// Les secrets provider vivent uniquement dans Vault (path = PaymentProviderState.vaultPath).
// ═════════════════════════════════════════════════════════════════════════════

// ── Intent : l'achat vu par le métier (billet, colis, facture, abonnement) ───
// Idempotent par (tenantId, idempotencyKey) — rejeu sûr depuis le front/Webhook.
// Le provider est choisi par PaymentRouter au moment de créer la première Attempt ;
// il peut changer au retry (MTN down → fallback Flutterwave).
model PaymentIntent {
  id             String    @id @default(cuid())
  tenantId       String
  // Idempotency-Key propagée depuis le client (header ou calculée côté serveur).
  // Unique par tenant : un même achat ne crée jamais deux Intents.
  idempotencyKey String
  // Référence métier (TICKET | PARCEL | INVOICE | SUBSCRIPTION | CUSTOM)
  entityType     String
  entityId       String? // ticketId | parcelId | invoiceId | subscriptionId
  // CRM — lien Customer (tenant-scoped), nullable (achat guest)
  customerId     String?
  // Montant TTC (taxes incluses, calculées par TaxCalculatorService en amont)
  amount         Float
  currency       String
  // Méthode demandée (le router choisit le provider concret derrière)
  method         String // MOBILE_MONEY | CARD | BANK_TRANSFER | USSD
  // Statut agrégé (dérivé de la dernière Attempt active)
  status         String    @default("CREATED")
  // CREATED | PROCESSING | SUCCEEDED | FAILED | CANCELLED | REFUNDED | PARTIALLY_REFUNDED | EXPIRED
  // Contexte client (never sensitive) — enrichi par l'orchestrator
  description    String?
  metadata       Json      @default("{}")
  // TTL — après expiresAt une Attempt ne peut plus être initiée (cron GC).
  expiresAt      DateTime
  settledAt      DateTime?
  // Décomposition fiscale figée au moment de la création (audit trail).
  // [{ code: 'TVA', label: 'TVA 18%', base: 'SUBTOTAL', kind: 'PERCENT', rate: 0.18, amount: 180 }, …]
  taxBreakdown   Json      @default("[]")
  subtotal       Float // Montant HT avant taxes
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  customer Customer?        @relation(fields: [customerId], references: [id])
  attempts PaymentAttempt[]
  events   PaymentEvent[]

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, customerId])
  @@index([tenantId, expiresAt])
  @@map("payment_intents")
}

// ── Attempt : une tentative concrète auprès d'un provider ────────────────────
// Chiffrement application-level des payloads bruts (clé Vault) — jamais en clair.
model PaymentAttempt {
  id                 String    @id @default(cuid())
  intentId           String
  // Clé du provider dans le registry ('mtn_momo_cg', 'airtel_cg', 'wave', 'flutterwave_agg'…)
  providerKey        String
  // Identifiant retourné par le provider (transaction_id Flutterwave, referenceId MTN…).
  // Peut être null jusqu'à la réponse du provider.
  externalRef        String?
  status             String    @default("INITIATED")
  // INITIATED | PENDING | SUCCESSFUL | FAILED | CANCELLED | REVERSED
  // Montant effectif de cette tentative (partiel pour retry possible).
  amount             Float
  currency           String
  // URL de redirection (flows card/hosted)
  paymentUrl         String?
  // Payloads bruts CHIFFRÉS (AES-GCM, clé rotative via Vault "platform/payments/app-key").
  requestEnc         String?   @db.Text
  responseEnc        String?   @db.Text
  // Erreur si échec
  failureCode        String?
  failureMessage     String?
  // Timestamps de corrélation webhook
  providerCallAt     DateTime?
  providerResolvedAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  intent PaymentIntent  @relation(fields: [intentId], references: [id], onDelete: Cascade)
  events PaymentEvent[]

  @@unique([providerKey, externalRef]) // dédup webhook par provider
  @@index([intentId, createdAt])
  @@index([providerKey, status])
  @@map("payment_attempts")
}

// ── Event : journal append-only (audit immuable) ─────────────────────────────
// Aucun UPDATE ni DELETE — seul INSERT. Utilisé pour reconstruction et audit.
model PaymentEvent {
  id        String   @id @default(cuid())
  intentId  String
  attemptId String? // null = event au niveau Intent (création, expiration…)
  type      String
  // INTENT_CREATED | ATTEMPT_STARTED | PROVIDER_CALLED | WEBHOOK_RECEIVED
  // | STATUS_CHANGED | REFUND_INITIATED | REFUND_COMPLETED | ERROR | EXPIRED
  payload   Json     @default("{}")
  source    String   @default("SYSTEM") // SYSTEM | WEBHOOK | CRON | USER
  createdAt DateTime @default(now())

  intent  PaymentIntent   @relation(fields: [intentId], references: [id], onDelete: Cascade)
  attempt PaymentAttempt? @relation(fields: [attemptId], references: [id], onDelete: SetNull)

  @@index([intentId, createdAt])
  @@index([attemptId, createdAt])
  @@index([type, createdAt])
  @@map("payment_events")
}

// ── ProviderState : toggle DISABLED | SANDBOX | LIVE par provider et tenant ──
// Règle : tenantId nullable — NULL = défaut plateforme (sandbox partout).
// Une ligne tenant surcharge la ligne plateforme. Le registry en module init
// ne retient que les providers dont mode != DISABLED.
model PaymentProviderState {
  id                    String    @id @default(cuid())
  tenantId              String? // null = défaut plateforme
  providerKey           String // 'mtn_momo_cg', 'airtel_cg', 'wave', 'flutterwave_agg', 'paystack_agg', 'stripe_cards'
  displayName           String
  mode                  String    @default("DISABLED") // DISABLED | SANDBOX | LIVE
  // Chemin Vault des secrets — lu par le connecteur (ex: "platform/payments/mtn_momo_cg").
  vaultPath             String
  // Méthodes supportées (MOBILE_MONEY, CARD, BANK_TRANSFER, USSD)
  supportedMethods      String[]  @default([])
  // Pays couverts (ISO 3166-1 alpha-2)
  supportedCountries    String[]  @default([])
  // Devises acceptées (ISO 4217)
  supportedCurrencies   String[]  @default([])
  // Santé
  lastHealthCheckAt     DateTime?
  lastHealthCheckStatus String? // UP | DOWN | DEGRADED
  lastHealthCheckError  String?
  // Activation (LIVE nécessite MFA + audit)
  activatedBy           String?
  activatedAt           DateTime?
  notes                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, providerKey])
  @@index([tenantId, mode])
  @@index([providerKey])
  @@map("payment_provider_states")
}

// ── OAuthProviderState : état d'activation des providers OAuth par tenant ────
// Mirror de PaymentProviderState (même pattern : nullable tenantId, mode DISABLED|SANDBOX|LIVE,
// audit trail activatedBy/activatedAt). Credentials côté Vault au chemin
// `platform/auth/<providerKey>` — jamais en DB ni en env var.
model OAuthProviderState {
  id                    String    @id @default(cuid())
  tenantId              String? // null = défaut plateforme
  providerKey           String // 'google', 'microsoft', 'facebook'
  displayName           String
  mode                  String    @default("DISABLED") // DISABLED | SANDBOX | LIVE
  // Chemin Vault des secrets (ex: "platform/auth/google")
  vaultPath             String
  // Santé (résultat du dernier healthcheck — validation creds)
  lastHealthCheckAt     DateTime?
  lastHealthCheckStatus String? // UP | DOWN | DEGRADED
  lastHealthCheckError  String?
  // Activation (LIVE nécessite MFA step-up + audit)
  activatedBy           String?
  activatedAt           DateTime?
  notes                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, providerKey])
  @@index([tenantId, mode])
  @@index([providerKey])
  @@map("oauth_provider_states")
}

// ── EmailProviderState : état des providers email côté plateforme ───────────
// Contrairement aux autres, l'email est plateforme-global (pas tenant-scoped).
// Un seul provider est actif à la fois (choisi via env var EMAIL_PROVIDER).
// Cette table sert à stocker les résultats de healthcheck + métadonnées UI
// (activatedAt, dernier test, dernier échec). tenantId est TOUJOURS null.
model EmailProviderState {
  id                    String    @id @default(cuid())
  providerKey           String    @unique // 'console' | 'smtp' | 'resend' | 'o365'
  displayName           String
  // Chemin Vault des secrets (ex: "platform/email/smtp"). null pour console.
  vaultPath             String?
  lastHealthCheckAt     DateTime?
  lastHealthCheckStatus String? // UP | DOWN | DEGRADED
  lastHealthCheckError  String?
  notes                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("email_provider_states")
}

// ── TenantTax : taxes multiples empilables (remplace tvaEnabled/tvaRate) ─────
// Seed-migration depuis TenantBusinessConfig au provisioning.
// base = SUBTOTAL  → taxe appliquée au HT (classique)
// base = TOTAL_AFTER_PREVIOUS → taxe appliquée à (HT + taxes précédentes selon sortOrder)
model TenantTax {
  id        String    @id @default(cuid())
  tenantId  String
  // Code court identifiant (TVA, TIMBRE, TAXE_GARE, TAXE_COMMUNALE, …)
  code      String
  // Libellé affiché (traduit via labelKey si présent)
  label     String
  labelKey  String? // clé i18n optionnelle (ex: 'tax.tva')
  // Valeur numérique — pourcentage (0.18) ou montant fixe (500)
  rate      Float
  kind      String    @default("PERCENT") // PERCENT | FIXED
  // Base de calcul
  base      String    @default("SUBTOTAL") // SUBTOTAL | TOTAL_AFTER_PREVIOUS
  // Types d'entités concernés ('TICKET', 'PARCEL', 'SUBSCRIPTION', 'ALL')
  appliesTo String[]  @default(["ALL"])
  // Ordre d'application (petit = appliqué en premier, utile pour cascade)
  sortOrder Int       @default(0)
  enabled   Boolean   @default(true)
  // Versioning fiscal — permet une bascule nette à date (loi de finances)
  validFrom DateTime?
  validTo   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId, enabled])
  @@map("tenant_taxes")
}

// ── TenantPaymentConfig : toutes les constantes paiement par tenant ──────────
// Créé automatiquement au provisioning avec les valeurs par défaut (seed).
// Toute la logique métier lit ici — jamais de magic number en dur.
model TenantPaymentConfig {
  id       String @id @default(cuid())
  tenantId String @unique

  // ── Routing provider par méthode ────────────────────────────────────────
  // { "MOBILE_MONEY": "flutterwave_agg", "CARD": "flutterwave_agg", … }
  // Fallback : PaymentRouter recherche par pays dans PaymentMethodConfig.
  defaultProviderByMethod Json @default("{}")
  // Liste ordonnée de providers de fallback par méthode
  // { "MOBILE_MONEY": ["mtn_momo_cg", "airtel_cg", "flutterwave_agg"] }
  fallbackChainByMethod   Json @default("{}")

  // ── Limites de montants (devise = Tenant.currency) ──────────────────────
  // { "MOBILE_MONEY": 100, "CARD": 500 }
  minAmountByMethod Json     @default("{}")
  maxAmountByMethod Json     @default("{}")
  // Devises acceptées par ce tenant. Vide = Tenant.currency uniquement.
  allowedCurrencies String[] @default([])

  // ── Timings (tous en minutes/secondes, pas de magic number) ─────────────
  intentTtlMinutes         Int @default(15) // TTL d'un Intent avant EXPIRED
  momoPushTimeoutSeconds   Int @default(90) // Timeout push MoMo avant FAILED
  webhookRetryMaxAttempts  Int @default(5)
  reconciliationLagMinutes Int @default(30) // Lag min avant tentative reconciliation

  // ── Frais & surcharges (répercussion au client) ─────────────────────────
  passProviderFeesToCustomer Boolean @default(false)
  // { "CARD": 0.025, "MOBILE_MONEY": 0.0 } — fraction appliquée en surcharge
  surchargePercentByMethod   Json    @default("{}")

  // ── Politique client ────────────────────────────────────────────────────
  // Méthodes exigeant un email client valide (cartes typiquement).
  requireCustomerEmailFor String[] @default([])
  allowGuestCheckout      Boolean  @default(true)

  // ── Seuils approbation & sécurité ───────────────────────────────────────
  // Montant au-delà duquel un refund nécessite MFA step-up (devise tenant).
  refundMfaThreshold Float @default(100000)

  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_payment_configs")
}

// ── PlatformPaymentConfig : constantes plateforme (singleton) ────────────────
// Une seule ligne (id='singleton'). Édité depuis l'UI Settings plateforme par SA.
model PlatformPaymentConfig {
  id                            String   @id @default("singleton")
  // Grace period avant PAST_DUE → SUSPENDED (heures)
  pastDueGraceHours             Int      @default(72)
  // Retry max global d'un webhook avant DLQ définitif
  globalWebhookRetryMax         Int      @default(5)
  // Backoff exponentiel initial (secondes) pour retry webhook
  webhookRetryInitialBackoffSec Int      @default(30)
  // Réconciliation
  reconciliationCronEnabled     Boolean  @default(true)
  reconciliationLagMinutes      Int      @default(30)
  // Alertes
  alertEmailOnGhostPayment      String?
  // Chiffrement application-level — rotation key path dans Vault
  payloadEncryptionVaultPath    String   @default("platform/payments/app-key")
  updatedAt                     DateTime @updatedAt

  @@map("platform_payment_config")
}

// ─── Waitlist (early-access prospects) ──────────────────────────────────────
// Captures les emails laissés sur la landing publique avant ouverture des
// inscriptions. Aucun lien avec Tenant/User — c'est un prospect, pas un compte.
// Unicité par email (une personne = une inscription) — on met à jour
// lastAttemptAt à chaque re-soumission plutôt que de dupliquer.
model Waitlist {
  id                String   @id @default(cuid())
  email             String   @unique
  locale            String? // langue du visiteur au moment de l'inscription (fr/en/…)
  source            String? // "landing_cta" | "landing_hero" | "referral" | …
  referrer          String? // document.referrer — analytics (optionnel)
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  ipHash            String? // SHA-256 de l'IP — anti-abus, pas identifiant PII
  userAgentHash     String? // SHA-256 user-agent — anti-bot soft
  createdAt         DateTime @default(now())
  lastAttemptAt     DateTime @default(now())
  attempts          Int      @default(1)
  // Converti en tenant ? (null tant que pas transformé)
  convertedTenantId String?

  @@index([createdAt])
  @@map("waitlist")
}
