// ============================================================
// TransLog Pro — Prisma Schema v3.0 (Post-PRD-ADD Integration)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// SECTION 1 : CORE & IDENTITY
// ─────────────────────────────────────────────────────────────

model Tenant {
  id              String            @id @default(uuid())
  name            String
  slug            String            @unique
  settings        Json              @default("{}")
  isActive        Boolean           @default(true)
  provisionStatus String            @default("PENDING")
  // PENDING | PROVISIONING | ACTIVE | SUSPENDED
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  users           User[]
  agencies        Agency[]
  modules         InstalledModule[]
  routes          Route[]
  trips           Trip[]
  workflowConfigs WorkflowConfig[]
  pricingRules    PricingRules[]
  buses           Bus[]
  stations        Station[]
  parcels         Parcel[]

  @@map("tenants")
}

model Agency {
  id        String  @id @default(cuid())
  tenantId  String
  name      String
  stationId String?

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  station       Station?      @relation(fields: [stationId], references: [id])
  users         User[]
  cashRegisters CashRegister[]

  @@index([tenantId])
  @@map("agencies")
}

model User {
  id          String   @id @default(cuid())
  tenantId    String
  agencyId    String?
  email       String   @unique
  name        String?
  image       String?
  roleId      String?
  userType    String   @default("STAFF") // STAFF | VOYAGEUR | ANONYMOUS
  preferences Json     @default("{}")    // siège préféré, gares fav (voyageurs)
  loyaltyScore Float   @default(0)       // calculé — voyageurs uniquement
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant                 Tenant                  @relation(fields: [tenantId], references: [id])
  agency                 Agency?                 @relation(fields: [agencyId], references: [id])
  role                   Role?                   @relation(fields: [roleId], references: [id])
  sessions               Session[]
  accounts               Account[]
  auditLogs              AuditLog[]
  checklists             Checklist[]
  staffProfile           Staff?
  notificationPreference NotificationPreference?
  feedbacks              Feedback[]
  safetyAlerts           SafetyAlert[]

  @@index([tenantId])
  @@index([tenantId, agencyId])
  @@index([tenantId, userType])
  @@map("users")
}

model Role {
  id          String           @id @default(uuid())
  tenantId    String
  name        String
  isSystem    Boolean          @default(false) // rôles système non supprimables
  permissions RolePermission[]
  users       User[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

// Permission: référence canonique (lookup/description uniquement)
model Permission {
  id          String  @id @default(cuid())
  key         String  @unique
  // FORMAT: {plane}.{module}.{action}.{scope}
  description String

  @@map("permissions")
}

// RolePermission: source de vérité runtime — stocke la string directement
// Le guard interroge cette table + Redis cache 60s (clé: iam:perm:{roleId}:{permission})
model RolePermission {
  id         String @id @default(cuid())
  roleId     String
  permission String // ex: "data.ticket.scan.agency"
  role       Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permission])
  @@index([roleId])
  @@map("role_permissions")
}

// ─────────────────────────────────────────────────────────────
// SECTION 2 : AUTH (Better Auth)
// ─────────────────────────────────────────────────────────────

model Session {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@map("sessions")
}

model Account {
  id           String  @id @default(cuid())
  userId       String
  providerId   String
  accountId    String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@map("accounts")
}

// ─────────────────────────────────────────────────────────────
// SECTION 3 : MODULES & CONFIGURATION
// ─────────────────────────────────────────────────────────────

model InstalledModule {
  id        String @id @default(cuid())
  tenantId  String
  moduleKey String
  // YIELD_ENGINE | GARAGE_PRO | SAV_MODULE | SCHEDULER | QUOTA_MANAGER
  config    Json   @default("{}")
  isActive  Boolean @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, moduleKey])
  @@map("installed_modules")
}

model NotificationPreference {
  id        String  @id @default(cuid())
  userId    String  @unique
  tenantId  String
  sms       Boolean @default(true)
  whatsapp  Boolean @default(true)
  push      Boolean @default(true)
  email     Boolean @default(false)

  user User @relation(fields: [userId], references: [id])

  @@map("notification_preferences")
}

// ─────────────────────────────────────────────────────────────
// SECTION 4 : WORKFLOW ENGINE
// ─────────────────────────────────────────────────────────────

model WorkflowConfig {
  id            String   @id @default(cuid())
  tenantId      String
  entityType    String
  // TICKET | PARCEL | TRIP | BUS | TRAVELER | SHIPMENT
  fromState     String
  action        String
  toState       String
  requiredPerm  String   // ex: "data.ticket.scan.agency"
  guards        Json     @default("[]")      // GuardDefinition[]
  sideEffects   Json     @default("[]")      // SideEffectDefinition[]
  version       Int      @default(1)
  effectiveFrom DateTime @default(now())
  isActive      Boolean  @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, entityType, fromState, action, version])
  @@index([tenantId, entityType, isActive])
  @@map("workflow_configs")
}

model WorkflowTransition {
  id             String   @id @default(cuid())
  idempotencyKey String   @unique
  tenantId       String
  entityType     String
  entityId       String
  action         String
  fromState      String
  toState        String
  userId         String
  createdAt      DateTime @default(now())

  @@index([entityType, entityId])
  @@index([tenantId, createdAt])
  @@map("workflow_transitions")
}

// ─────────────────────────────────────────────────────────────
// SECTION 5 : AUDIT & EVENTS
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  userId    String?
  tenantId  String
  plane     String   // control | data
  level     String   // info | warn | critical
  action    String   // ex: "data.ticket.board.agency"
  resource  String   // ex: "Ticket:clx..."
  oldValue  Json?
  newValue  Json?
  ipAddress String?

  user User? @relation(fields: [userId], references: [id])

  // Partitionnement RANGE mensuel défini via migration SQL brute
  @@index([tenantId, createdAt])
  @@index([tenantId, action])
  @@index([resource])
  @@map("audit_logs")
}

model OutboxEvent {
  id            String    @id @default(cuid())
  tenantId      String
  eventType     String    // ex: "ticket.boarded"
  aggregateType String    // TICKET | TRIP | PARCEL | ...
  aggregateId   String
  payload       Json
  status        String    @default("PENDING")
  // PENDING | PROCESSING | DELIVERED | FAILED | DEAD
  attempts      Int       @default(0)
  lastError     String?
  scheduledAt   DateTime  @default(now())
  processedAt   DateTime?
  createdAt     DateTime  @default(now())

  @@index([status, scheduledAt])
  @@index([tenantId, eventType])
  @@map("outbox_events")
}

model DeadLetterEvent {
  id          String    @id @default(cuid())
  tenantId    String
  eventType   String
  aggregateId String
  payload     Json
  errorLog    Json      @default("[]")
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?

  @@index([tenantId, resolvedAt])
  @@map("dead_letter_events")
}

// ─────────────────────────────────────────────────────────────
// SECTION 6 : GÉOGRAPHIE & INFRASTRUCTURE
// ─────────────────────────────────────────────────────────────

model Station {
  id          String  @id @default(cuid())
  tenantId    String
  name        String
  coordinates Json    // { lat: Float, lng: Float }
  type        String  // PRINCIPALE | RELAIS

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  agencies    Agency[]
  routesOrigin      Route[]  @relation("RouteOrigin")
  routesDestination Route[]  @relation("RouteDestination")
  waypoints         Waypoint[]
  parcelsTo         Parcel[]   @relation("ParcelDestination")
  shipmentsTo       Shipment[] @relation("ShipmentDestination")
  travelersDropoff  Traveler[] @relation("TravelerDropOff")

  @@index([tenantId])
  @@map("stations")
}

model Route {
  id            String @id @default(cuid())
  tenantId      String
  name          String
  originId      String
  destinationId String
  distanceKm    Float
  basePrice     Float

  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  origin      Station    @relation("RouteOrigin", fields: [originId], references: [id])
  destination Station    @relation("RouteDestination", fields: [destinationId], references: [id])
  waypoints   Waypoint[]
  trips       Trip[]

  @@index([tenantId])
  @@map("routes")
}

model Waypoint {
  id                String  @id @default(cuid())
  routeId           String
  stationId         String
  order             Int
  isMandatoryStop   Boolean @default(false)
  estimatedWaitTime Int?    // minutes
  isAlertZone       Boolean @default(false)
  alertDescription  String?

  route   Route   @relation(fields: [routeId], references: [id])
  station Station @relation(fields: [stationId], references: [id])

  @@unique([routeId, order])
  @@map("waypoints")
}

// ─────────────────────────────────────────────────────────────
// SECTION 7 : FLOTTE & PERSONNEL
// ─────────────────────────────────────────────────────────────

model Bus {
  id                  String  @id @default(cuid())
  tenantId            String
  plateNumber         String  @unique
  model               String
  capacity            Int
  luggageCapacityKg   Float
  luggageCapacityM3   Float
  seatLayout          Json?   // Plan de salle numéroté — OBLIGATOIRE avant vente
  status              String  @default("AVAILABLE")
  // AVAILABLE | BOARDING | DEPARTED | ARRIVED | MAINTENANCE | CLOSED | IN_SERVICE
  version             Int     @default(1)

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  trips              Trip[]
  maintenanceReports MaintenanceReport[]

  @@index([tenantId, status])
  @@map("buses")
}

model Staff {
  id                  String  @id @default(cuid())
  tenantId            String
  agencyId            String?
  userId              String  @unique
  role                String  // DRIVER | HOSTESS | MECHANIC
  status              String  @default("ACTIVE")  // ACTIVE | SUSPENDED
  licenseData         Json    @default("{}")
  isAvailable         Boolean @default(true)
  totalDriveTimeToday Float   @default(0)
  createdAt           DateTime @default(now())
  // Remis à 0 chaque jour à minuit par un scheduler

  user User @relation(fields: [userId], references: [id])

  @@index([tenantId, role, isAvailable])
  @@map("staff")
}

// ─────────────────────────────────────────────────────────────
// SECTION 8 : TRAJETS & OPÉRATIONS
// ─────────────────────────────────────────────────────────────

model Trip {
  id                 String   @id @default(cuid())
  tenantId           String
  routeId            String
  busId              String
  driverId           String
  status             String   @default("PLANNED")
  // PLANNED | OPEN | BOARDING | IN_PROGRESS | IN_PROGRESS_PAUSED
  // IN_PROGRESS_DELAYED | COMPLETED | CANCELLED
  roadbook           Json     @default("{}")
  // Stocké en DB (pas MinIO) pour permettre les requêtes sur waypoints
  departureScheduled DateTime
  arrivalScheduled   DateTime
  currentLat         Float?
  currentLng         Float?
  lastGpsAt          DateTime?
  displayNote        String?  // texte court pour écrans d'affichage gare
  displayColor       String?  // code couleur hex (#FF9800 = ambre retard)
  version            Int      @default(1)

  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  route       Route           @relation(fields: [routeId], references: [id])
  bus         Bus             @relation(fields: [busId], references: [id])
  checklists  Checklist[]
  incidents   Incident[]
  shipments   Shipment[]
  tripEvents  TripEvent[]
  crewAssignments CrewAssignment[]
  feedbacks   Feedback[]
  travelers   Traveler[]      @relation("TripTravelers")

  @@index([tenantId, status])
  @@index([tenantId, departureScheduled])
  @@map("trips")
}

model Checklist {
  id          String   @id @default(cuid())
  tripId      String
  userId      String
  type        String
  // PRE_DEPARTURE | BOARDING_READY | POST_TRIP | MAINTENANCE
  content     Json     @default("{}")
  isCompliant Boolean  @default(false)
  createdAt   DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([tripId, type])
  @@map("checklists")
}

// Incident: événement exceptionnel nécessitant une réponse humaine (SOS, panne, etc.)
// Partage l'interface BaseEvent avec TripEvent — voir src/common/types/base-event.type.ts
model Incident {
  id                  String    @id @default(cuid())
  tenantId            String
  tripId              String?
  busId               String?
  reportedById        String
  type                String    // MECHANICAL | SECURITY | HEALTH | LOST_OBJECT | SOS | ACCIDENT
  severity            String    // LOW | MEDIUM | HIGH | CRITICAL
  description         String
  locationDescription String?
  metadata            Json      @default("{}")
  isSos               Boolean   @default(false)
  status              String    @default("OPEN")
  // OPEN | ASSIGNED | IN_PROGRESS | RESOLVED | CLOSED
  assigneeId          String?
  resolution          String?
  resolvedAt          DateTime?
  claimId             String?   // FK vers Claim si incident déclenche un SAV
  createdAt           DateTime  @default(now())

  trip Trip? @relation(fields: [tripId], references: [id])

  @@index([tenantId, tripId, type])
  @@index([tenantId, severity, resolvedAt])
  @@index([tenantId, isSos, status])
  @@map("incidents")
}

model MaintenanceReport {
  id            String    @id @default(cuid())
  tenantId      String
  busId         String
  incidentId    String?
  type          String    // PREVENTIVE | CORRECTIVE | EMERGENCY
  description   String
  scheduledAt   DateTime
  odometer      Float?
  partsUsed     Json      @default("[]")
  status        String    @default("SCHEDULED")
  // SCHEDULED | IN_PROGRESS | COMPLETED | APPROVED
  notes         String?
  createdById   String
  completedAt   DateTime?
  completedById String?
  approvedById  String?
  approvedAt    DateTime?
  createdAt     DateTime  @default(now())

  bus Bus @relation(fields: [busId], references: [id])

  @@index([tenantId, busId])
  @@index([tenantId, status])
  @@map("maintenance_reports")
}

// ─────────────────────────────────────────────────────────────
// SECTION 9 : BILLETTERIE & PASSAGERS
// ─────────────────────────────────────────────────────────────

model Ticket {
  id            String   @id @default(cuid())
  tenantId      String
  tripId        String
  passengerId   String
  passengerName String
  seatNumber    String?
  pricePaid     Float
  status        String   @default("CREATED")
  // CREATED | PENDING_PAYMENT | CONFIRMED | CHECKED_IN | BOARDED | COMPLETED
  // CANCELLED | EXPIRED
  expiresAt     DateTime?
  qrCode        String   @unique
  // Format: base64url(payload).HMAC-SHA256(payload, tenant_hmac_key)
  agencyId      String
  version       Int      @default(1)
  createdAt     DateTime @default(now())

  @@index([tenantId, tripId, status])
  @@index([qrCode])
  @@index([tenantId, agencyId])
  @@map("tickets")
}

model Traveler {
  id               String  @id @default(cuid())
  tenantId         String
  ticketId         String  @unique
  tripId           String
  status           String  @default("VERIFIED")
  // VERIFIED | CHECKED_IN | BOARDED | ARRIVED | EXITED
  dropOffStationId String?
  version          Int     @default(1)

  dropOffStation Station? @relation("TravelerDropOff", fields: [dropOffStationId], references: [id])
  trip           Trip     @relation("TripTravelers", fields: [tripId], references: [id])

  @@index([tenantId, tripId, status])
  @@index([tripId, dropOffStationId])
  @@map("travelers")
}

model Baggage {
  id       String @id @default(cuid())
  tenantId String
  ticketId String
  count    Int    @default(1)
  weight   Float
  type     String // CABIN | HOLD
  surcharge Float  @default(0)

  @@index([ticketId])
  @@map("baggages")
}

// ─────────────────────────────────────────────────────────────
// SECTION 10 : COLIS & EXPÉDITIONS
// ─────────────────────────────────────────────────────────────

model Parcel {
  id            String   @id @default(cuid())
  tenantId      String
  senderId      String
  trackingCode  String   @unique
  weight        Float
  price         Float
  destinationId String   // FK Station (plus un String libre)
  recipientInfo Json     // { name, phone, address }
  shipmentId    String?
  status        String   @default("CREATED")
  // CREATED | AT_ORIGIN | PACKED | LOADED | IN_TRANSIT | ARRIVED | DELIVERED | DAMAGED
  history       Json     @default("[]")
  // [{ timestamp, agentId, stationId, action }]
  version       Int      @default(1)
  createdAt     DateTime @default(now())

  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  destination Station   @relation("ParcelDestination", fields: [destinationId], references: [id])
  shipment    Shipment? @relation(fields: [shipmentId], references: [id])

  @@index([tenantId, status])
  @@index([trackingCode])
  @@index([tenantId, destinationId])
  @@map("parcels")
}

model Shipment {
  id              String   @id @default(cuid())
  tenantId        String
  tripId          String
  destinationId   String   // FK Station (plus un String libre)
  totalWeight     Float    @default(0)
  remainingWeight Float
  status          String   @default("OPEN")
  // OPEN | LOADED | IN_TRANSIT | ARRIVED | CLOSED
  version         Int      @default(1)
  createdAt       DateTime @default(now())

  trip        Trip      @relation(fields: [tripId], references: [id])
  destination Station   @relation("ShipmentDestination", fields: [destinationId], references: [id])
  parcels     Parcel[]

  @@index([tenantId, tripId])
  @@map("shipments")
}

// ─────────────────────────────────────────────────────────────
// SECTION 11 : FINANCE & CAISSE
// ─────────────────────────────────────────────────────────────

model PricingRules {
  id       String @id @default(cuid())
  tenantId String
  routeId  String
  rules    Json
  // {
  //   basePrice: Float, taxRate: Float, tollCost: Float,
  //   pricePerKm: Float, luggageQuotaKg: Float, surchargePerKg: Float,
  //   yieldConfig: { enabled: Boolean, tiers: [...] }
  // }

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, routeId])
  @@map("pricing_rules")
}

model CashRegister {
  id             String        @id @default(cuid())
  tenantId       String
  agencyId       String
  agentId        String
  openedAt       DateTime      @default(now())
  closedAt       DateTime?
  initialBalance Float
  finalBalance   Float?
  auditStatus    String        @default("OPEN")
  // OPEN | CLOSED | DISCREPANCY

  agency       Agency        @relation(fields: [agencyId], references: [id])
  transactions Transaction[]

  @@index([tenantId, agencyId, auditStatus])
  @@map("cash_registers")
}

model Transaction {
  id              String   @id @default(cuid())
  tenantId        String
  cashRegisterId  String
  type            String   // TICKET | PARCEL | LUGGAGE_FEE | REFUND
  amount          Float
  paymentMethod   String   // CASH | MOBILE_MONEY
  externalRef     String?  // Référence Flutterwave/Paystack (idempotent)
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now())

  cashRegister CashRegister @relation(fields: [cashRegisterId], references: [id])

  @@index([tenantId, createdAt])
  @@index([externalRef])
  @@map("transactions")
}

// ─────────────────────────────────────────────────────────────
// SECTION 12 : SAV & OBJETS TROUVÉS
// ─────────────────────────────────────────────────────────────

model LostFoundItem {
  id           String    @id @default(cuid())
  tenantId     String
  tripId       String
  reporterId   String
  description  String
  photoUrl     String?   // MinIO signed URL — TTL 30 jours post-remise
  status       String    @default("FOUND")
  // FOUND | CLAIMED | DISPOSED
  claimedAt    DateTime?
  claimedBy    String?
  signatureUrl String?   // Photo pièce ID — TTL 15min (biométrique)
  createdAt    DateTime  @default(now())

  @@index([tenantId, status])
  @@map("lost_found_items")
}

model Claim {
  id          String    @id @default(cuid())
  tenantId    String
  type        String    // PARCEL_DAMAGE | PARCEL_LOSS | SERVICE | REFUND_REQUEST | SAFETY
  reporterId  String
  entityId    String    // parcelId ou ticketId
  entityType  String    // PARCEL | TICKET | INCIDENT
  description String
  status      String    @default("OPEN")
  // OPEN | UNDER_INVESTIGATION | RESOLVED | REJECTED | CLOSED
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime  @default(now())

  @@index([tenantId, status])
  @@map("claims")
}

// ─────────────────────────────────────────────────────────────
// SECTION 13 : TRIP EVENTS (pauses, checkpoints, délais — PRD §IV.11)
// ─────────────────────────────────────────────────────────────

// TripEvent: événements opérationnels normaux du voyage (pauses, checkpoints GPS, délais)
// Partage l'interface BaseEvent avec Incident — discriminé par le champ type
model TripEvent {
  id          String   @id @default(cuid())
  tenantId    String
  tripId      String
  type        String
  // PAUSE_START | PAUSE_END | CHECKPOINT_REACHED | DELAY_DECLARED
  // DELAY_DETECTED | DEPARTURE_ANOMALY | GEOFENCE_EXIT
  severity    String   @default("LOW")  // LOW | MEDIUM | HIGH | CRITICAL
  reportedBy  String   // userId du chauffeur ou 'SYSTEM'
  gpsLat      Float?
  gpsLng      Float?
  metadata    Json     @default("{}")   // durée pause, nom checkpoint, etc.
  claimId     String?                   // FK Claim si l'événement déclenche un SAV
  createdAt   DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id])

  @@index([tenantId, tripId, type])
  @@index([tenantId, createdAt])
  @@map("trip_events")
}

// ─────────────────────────────────────────────────────────────
// SECTION 14 : SAFETY & FEEDBACK (PRD §IV.13)
// ─────────────────────────────────────────────────────────────

model SafetyAlert {
  id                String   @id @default(cuid())
  tenantId          String
  tripId            String?
  reporterId        String
  type              String   // DANGEROUS_DRIVING | ACCIDENT | BREAKDOWN | OTHER
  description       String?
  gpsLat            Float?
  gpsLng            Float?
  verificationScore Float    @default(0)  // 0..1 — corrélation GPS bus/déclarant
  status            String   @default("PENDING")
  // PENDING | VERIFIED | UNVERIFIED | DISMISSED
  source            String   @default("IN_APP") // IN_APP | PUBLIC_REPORT
  createdAt         DateTime @default(now())

  reporter User @relation(fields: [reporterId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, tripId])
  @@map("safety_alerts")
}

// Feedback: note brute soumise par un voyageur après un trajet
model Feedback {
  id             String   @id @default(cuid())
  tenantId       String
  userId         String
  tripId         String?
  driverId       String?  // Staff.id
  busId          String?
  agencyId       String?
  ratings        Json     @default("{}")
  // { conduct: 0-5, punctuality: 0-5, comfort: 0-5, baggage: 0-5 }
  comment        String?
  rgpdConsentAt  DateTime // consentement RGPD obligatoire à la soumission
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  trip Trip? @relation(fields: [tripId], references: [id])

  @@index([tenantId, tripId])
  @@index([driverId])
  @@index([busId])
  @@map("feedbacks")
}

// Rating: agrégat calculé — mis à jour asynchroniquement via side effect trip.completed
model Rating {
  id          String   @id @default(cuid())
  tenantId    String
  entityType  String   // DRIVER | BUS | AGENCY
  entityId    String   // Staff.id | Bus.id | Agency.id
  avgScore    Float    @default(0)
  count       Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, entityType, entityId])
  @@index([tenantId, entityType])
  @@map("ratings")
}

// ─────────────────────────────────────────────────────────────
// SECTION 15 : CREW OPERATIONS (PRD §IV.15)
// ─────────────────────────────────────────────────────────────

model CrewAssignment {
  id        String    @id @default(cuid())
  tenantId  String
  tripId    String
  staffId   String
  crewRole  String    // CO_PILOT | HOSTESS | SECURITY | MECHANIC_ON_BOARD
  briefedAt DateTime? // null = pas encore briefé (guard CREW_BRIEFED)
  createdAt DateTime  @default(now())

  trip Trip @relation(fields: [tripId], references: [id])

  @@unique([tripId, staffId])
  @@index([tenantId, tripId])
  @@map("crew_assignments")
}

// ─────────────────────────────────────────────────────────────
// SECTION 16 : PUBLIC REPORTER (PRD §IV.16)
// ─────────────────────────────────────────────────────────────

model PublicReport {
  id                  String    @id @default(cuid())
  tenantId            String
  plateOrParkNumber   String
  type                String    // DANGEROUS_DRIVING | ACCIDENT | BREAKDOWN | OTHER
  description         String
  reporterGpsLat      Float?
  reporterGpsLng      Float?
  reporterGpsExpireAt DateTime? // RGPD: suppression GPS après 24h
  verificationScore   Float     @default(0)
  status              String    @default("PENDING")
  // PENDING | VERIFIED | UNVERIFIED | DISMISSED
  correlatedBusId     String?
  photoUrl            String?
  reporterIp          String    // pour rate limiting audit
  createdAt           DateTime  @default(now())

  @@index([tenantId, status])
  @@index([plateOrParkNumber])
  @@map("public_reports")
}

// ─────────────────────────────────────────────────────────────
// SECTION 17 : CRM & CAMPAGNES (PRD §IV.12)
// ─────────────────────────────────────────────────────────────

model Campaign {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  criteria    Json     @default("{}")  // segments de voyageurs ciblés
  messageText String
  status      String   @default("DRAFT")
  // DRAFT | ACTIVE | PAUSED | COMPLETED
  sentCount   Int      @default(0)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, status])
  @@map("campaigns")
}

// ─────────────────────────────────────────────────────────────
// SECTION 17 : GPS & TEMPLATES
// ─────────────────────────────────────────────────────────────

model GpsPosition {
  id         String   @id @default(cuid())
  tenantId   String
  tripId     String
  lat        Float
  lng        Float
  speed      Float?
  heading    Float?
  recordedAt DateTime @default(now())

  @@index([tenantId, tripId, recordedAt])
  @@map("gps_positions")
}

model TripTemplate {
  id               String    @id @default(cuid())
  tenantId         String
  routeId          String
  weekdays         Json      // [0..6] jours de la semaine
  departureTime    String    // "HH:MM"
  defaultBusId     String?
  defaultDriverId  String?
  isActive         Boolean   @default(true)
  effectiveUntil   DateTime?
  createdAt        DateTime  @default(now())

  @@index([tenantId, isActive])
  @@map("trip_templates")
}
