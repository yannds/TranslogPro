{
  "_meta": {
    "slug": "invoice-simple-a5",
    "name": "Facture simplifiée A5",
    "docType": "INVOICE",
    "format": "A5",
    "engine": "PDFME",
    "description": "Facture A5 compacte pour vente agence ou marché — idéale pour impression rapide et distribution manuelle",
    "variables": [
      "tenantName", "tenantPhone", "tenantNif",
      "invoiceNumber", "invoiceDate",
      "clientName",
      "origin", "destination", "tripDate", "seatNumber",
      "price", "currency", "paymentMethod",
      "qrCodeValue"
    ]
  },
  "basePdf": { "width": 148, "height": 210, "padding": [10, 10, 10, 10] },
  "schemas": [[
    { "name": "tenantName", "type": "text",
      "position": {"x":10,"y":10}, "width":128, "height":8,
      "content": "{{tenantName}}", "fontSize":14, "fontColor":"#1a3a5c",
      "fontName":"NotoSans-Bold", "alignment":"left" },
    { "name": "tenantMeta", "type": "text",
      "position": {"x":10,"y":18}, "width":128, "height":5,
      "content": "NIF: {{tenantNif}}  ·  Tél: {{tenantPhone}}",
      "fontSize":7, "fontColor":"#6b7280" },
    { "name": "titleBg", "type": "rectangle",
      "position": {"x":10,"y":28}, "width":128, "height":12, "color":"#1a3a5c", "borderRadius":2 },
    { "name": "titleText", "type": "text",
      "position": {"x":14,"y":31}, "width":64, "height":8,
      "content": "FACTURE", "fontSize":12, "fontColor":"#ffffff", "fontName":"NotoSans-Bold" },
    { "name": "invoiceNumber", "type": "text",
      "position": {"x":80,"y":31}, "width":54, "height":8,
      "content": "{{invoiceNumber}}", "fontSize":10, "fontColor":"#ffffff",
      "fontName":"NotoSans-Bold", "alignment":"right" },
    { "name": "invoiceDate", "type": "text",
      "position": {"x":10,"y":43}, "width":128, "height":5,
      "content": "Émise le : {{invoiceDate}}",
      "fontSize":7, "fontColor":"#9ca3af", "alignment":"right" },

    { "name": "clientLabel", "type": "text",
      "position": {"x":10,"y":52}, "width":80, "height":5,
      "content": "CLIENT", "fontSize":7, "fontColor":"#9ca3af", "fontName":"NotoSans-Bold" },
    { "name": "clientName", "type": "text",
      "position": {"x":10,"y":58}, "width":128, "height":6,
      "content": "{{clientName}}", "fontSize":10, "fontColor":"#111827", "fontName":"NotoSans-Bold" },

    { "name": "tripBoxBg", "type": "rectangle",
      "position": {"x":10,"y":70}, "width":128, "height":36, "color":"#f9fafb", "borderRadius":3 },
    { "name": "routeText", "type": "text",
      "position": {"x":14,"y":75}, "width":120, "height":9,
      "content": "{{origin}} → {{destination}}", "fontSize":13, "fontColor":"#1a3a5c",
      "fontName":"NotoSans-Bold" },
    { "name": "tripDateLabel", "type": "text",
      "position": {"x":14,"y":87}, "width":50, "height":5,
      "content": "Départ", "fontSize":7, "fontColor":"#9ca3af" },
    { "name": "tripDate", "type": "text",
      "position": {"x":14,"y":92}, "width":60, "height":6,
      "content": "{{tripDate}}", "fontSize":9, "fontColor":"#111827" },
    { "name": "seatLabel", "type": "text",
      "position": {"x":80,"y":87}, "width":50, "height":5,
      "content": "Siège", "fontSize":7, "fontColor":"#9ca3af" },
    { "name": "seatNumber", "type": "text",
      "position": {"x":80,"y":92}, "width":54, "height":6,
      "content": "{{seatNumber}}", "fontSize":12, "fontColor":"#1a3a5c",
      "fontName":"NotoSans-Bold", "alignment":"right" },

    { "name": "totalBg", "type": "rectangle",
      "position": {"x":10,"y":115}, "width":128, "height":18, "color":"#1a3a5c", "borderRadius":3 },
    { "name": "totalLabel", "type": "text",
      "position": {"x":14,"y":119}, "width":60, "height":10,
      "content": "À PAYER", "fontSize":11, "fontColor":"#c7d2fe",
      "fontName":"NotoSans-Bold" },
    { "name": "totalAmount", "type": "text",
      "position": {"x":60,"y":119}, "width":72, "height":10,
      "content": "{{price}} {{currency}}", "fontSize":16, "fontColor":"#ffffff",
      "fontName":"NotoSans-Bold", "alignment":"right" },

    { "name": "paymentMethod", "type": "text",
      "position": {"x":10,"y":138}, "width":80, "height":5,
      "content": "Mode : {{paymentMethod}}", "fontSize":8, "fontColor":"#374151" },

    { "name": "qrCode", "type": "qrcode",
      "position": {"x":55,"y":150}, "width":38, "height":38,
      "content": "{{qrCodeValue}}" },
    { "name": "footer", "type": "text",
      "position": {"x":10,"y":192}, "width":128, "height":5,
      "content": "Merci de votre confiance.  Conservez ce document.",
      "fontSize":7, "fontColor":"#9ca3af", "alignment":"center" }
  ]]
}
