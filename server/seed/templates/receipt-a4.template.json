{
  "_meta": {
    "slug": "receipt-a4",
    "name": "Reçu de paiement A4",
    "docType": "TICKET",
    "format": "A4",
    "engine": "PDFME",
    "description": "Reçu officiel A4 à remettre au client — utilisable comme justificatif comptable, version bureau (hors caisse thermique)",
    "variables": [
      "tenantName", "tenantAddress", "tenantPhone", "tenantNif", "tenantLogo",
      "receiptNumber", "receiptDate", "clientName", "clientPhone",
      "description", "amount", "currency", "paymentMethod", "paymentRef",
      "cashierName", "qrCodeValue", "generatedAt"
    ]
  },
  "basePdf": { "width": 210, "height": 297, "padding": [15, 14, 15, 14] },
  "schemas": [[
    { "name": "tenantName", "type": "text",
      "position": {"x":14,"y":15}, "width":120, "height":10,
      "content": "{{tenantName}}", "fontSize":18, "fontColor":"#1a3a5c",
      "fontName":"NotoSans-Bold", "alignment":"left" },
    { "name": "tenantMeta", "type": "text",
      "position": {"x":14,"y":25}, "width":120, "height":6,
      "content": "NIF: {{tenantNif}} · {{tenantAddress}} · Tél: {{tenantPhone}}",
      "fontSize":7, "fontColor":"#6b7280" },
    { "name": "titleBg", "type": "rectangle",
      "position": {"x":140,"y":15}, "width":56, "height":20, "color":"#f59e0b", "borderRadius":3 },
    { "name": "titleText", "type": "text",
      "position": {"x":140,"y":20}, "width":56, "height":10,
      "content": "REÇU", "fontSize":18, "fontColor":"#ffffff",
      "fontName":"NotoSans-Bold", "alignment":"center" },
    { "name": "divider1", "type": "line",
      "position": {"x":14,"y":40}, "width":182, "height":0.4, "color":"#d1d5db" },

    { "name": "numLabel", "type": "text",
      "position": {"x":14,"y":46}, "width":40, "height":5,
      "content": "N° Reçu", "fontSize":7, "fontColor":"#9ca3af" },
    { "name": "receiptNumber", "type": "text",
      "position": {"x":14,"y":51}, "width":80, "height":7,
      "content": "{{receiptNumber}}", "fontSize":12, "fontColor":"#111827",
      "fontName":"NotoSans-Bold" },
    { "name": "dateLabel", "type": "text",
      "position": {"x":140,"y":46}, "width":56, "height":5,
      "content": "Date", "fontSize":7, "fontColor":"#9ca3af", "alignment":"right" },
    { "name": "receiptDate", "type": "text",
      "position": {"x":140,"y":51}, "width":56, "height":7,
      "content": "{{receiptDate}}", "fontSize":11, "fontColor":"#111827", "alignment":"right" },

    { "name": "clientBoxBg", "type": "rectangle",
      "position": {"x":14,"y":65}, "width":182, "height":22, "color":"#f9fafb", "borderRadius":3 },
    { "name": "clientLabel", "type": "text",
      "position": {"x":17,"y":68}, "width":60, "height":5,
      "content": "Reçu de", "fontSize":7, "fontColor":"#9ca3af" },
    { "name": "clientName", "type": "text",
      "position": {"x":17,"y":73}, "width":176, "height":7,
      "content": "{{clientName}}", "fontSize":12, "fontColor":"#111827",
      "fontName":"NotoSans-Bold" },
    { "name": "clientPhone", "type": "text",
      "position": {"x":17,"y":81}, "width":176, "height":5,
      "content": "Tél: {{clientPhone}}", "fontSize":8, "fontColor":"#374151" },

    { "name": "descLabel", "type": "text",
      "position": {"x":14,"y":100}, "width":120, "height":5,
      "content": "OBJET DU PAIEMENT", "fontSize":7, "fontColor":"#9ca3af",
      "fontName":"NotoSans-Bold" },
    { "name": "description", "type": "text",
      "position": {"x":14,"y":107}, "width":182, "height":20,
      "content": "{{description}}", "fontSize":10, "fontColor":"#111827", "lineHeight":1.5 },

    { "name": "amountBoxBg", "type": "rectangle",
      "position": {"x":14,"y":140}, "width":182, "height":28, "color":"#1a3a5c", "borderRadius":4 },
    { "name": "amountLabel", "type": "text",
      "position": {"x":18,"y":146}, "width":80, "height":6,
      "content": "MONTANT REÇU", "fontSize":9, "fontColor":"#c7d2fe",
      "fontName":"NotoSans-Bold" },
    { "name": "amount", "type": "text",
      "position": {"x":18,"y":153}, "width":174, "height":12,
      "content": "{{amount}} {{currency}}", "fontSize":22, "fontColor":"#ffffff",
      "fontName":"NotoSans-Bold", "alignment":"right" },

    { "name": "methodLabel", "type": "text",
      "position": {"x":14,"y":175}, "width":90, "height":5,
      "content": "Mode de paiement", "fontSize":7, "fontColor":"#9ca3af" },
    { "name": "paymentMethod", "type": "text",
      "position": {"x":14,"y":180}, "width":90, "height":7,
      "content": "{{paymentMethod}}", "fontSize":11, "fontColor":"#111827",
      "fontName":"NotoSans-Bold" },
    { "name": "refLabel", "type": "text",
      "position": {"x":106,"y":175}, "width":90, "height":5,
      "content": "Référence transaction", "fontSize":7, "fontColor":"#9ca3af" },
    { "name": "paymentRef", "type": "text",
      "position": {"x":106,"y":180}, "width":90, "height":7,
      "content": "{{paymentRef}}", "fontSize":10, "fontColor":"#111827" },

    { "name": "qrCode", "type": "qrcode",
      "position": {"x":14,"y":220}, "width":30, "height":30,
      "content": "{{qrCodeValue}}" },
    { "name": "cashierLabel", "type": "text",
      "position": {"x":120,"y":235}, "width":76, "height":5,
      "content": "Encaissé par", "fontSize":7, "fontColor":"#9ca3af", "alignment":"right" },
    { "name": "cashierName", "type": "text",
      "position": {"x":120,"y":240}, "width":76, "height":7,
      "content": "{{cashierName}}", "fontSize":10, "fontColor":"#111827",
      "fontName":"NotoSans-Bold", "alignment":"right" },
    { "name": "sigLine", "type": "line",
      "position": {"x":140,"y":252}, "width":56, "height":0.3, "color":"#9ca3af" },
    { "name": "sigLabel", "type": "text",
      "position": {"x":140,"y":253}, "width":56, "height":5,
      "content": "Signature & cachet", "fontSize":6, "fontColor":"#9ca3af", "alignment":"center" },

    { "name": "footer", "type": "text",
      "position": {"x":14,"y":278}, "width":182, "height":5,
      "content": "Document généré le {{generatedAt}} — Ce reçu tient lieu de justificatif officiel",
      "fontSize":6.5, "fontColor":"#9ca3af", "alignment":"center" }
  ]]
}
