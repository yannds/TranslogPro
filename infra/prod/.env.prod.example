# ═════════════════════════════════════════════════════════════════════════════
# TransLog Pro — .env.prod (PRODUCTION)
# ═════════════════════════════════════════════════════════════════════════════
# NE JAMAIS COMMITER ce fichier (gitignore le protège).
# Généré par ./scripts/02-gen-secrets.sh sur le VPS.
# Permissions : chmod 600, owner root.
# ═════════════════════════════════════════════════════════════════════════════

# ─── Application ─────────────────────────────────────────────────────────────
APP_VERSION=1.0.0
NODE_ENV=production

# Base domaines (miroirs host-config.service.ts + frontend/lib/tenancy/host.ts)
PLATFORM_BASE_DOMAIN=translog.dsyann.info
PUBLIC_BASE_DOMAIN=translog.dsyann.info
PUBLIC_APP_URL=https://translog-admin.dsyann.info
PUBLIC_PORTAL_URL=https://translog-admin.dsyann.info
PUBLIC_TRACKING_URL=https://translog-admin.dsyann.info

# ─── Let's Encrypt / ACME ────────────────────────────────────────────────────
ACME_EMAIL=yannds@gmail.com

# ─── TSIG key (BIND9 ↔ Caddy) — GÉNÉRÉ PAR 02-gen-secrets.sh ─────────────────
TSIG_KEY_NAME=translog-acme.
TSIG_ALG=hmac-sha256
TSIG_SECRET=REPLACE_WITH_GENERATED_BASE64_32B

# ─── Postgres — 3 rôles distincts (NE PAS partager app_admin en runtime) ─────
# app_admin: migrations Prisma, DDL (POSTGRES_USER/POSTGRES_PASSWORD)
POSTGRES_APP_ADMIN_PASSWORD=REPLACE_WITH_RANDOM_32B

# app_runtime: backend NestJS (NOBYPASSRLS — OBLIGATOIRE pour isolation multi-tenant)
POSTGRES_APP_RUNTIME_PASSWORD=REPLACE_WITH_RANDOM_32B

# app_superadmin: support L2 (NOBYPASSRLS aussi — pas de privilège bypass)
POSTGRES_APP_SUPERADMIN_PASSWORD=REPLACE_WITH_RANDOM_32B

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=REPLACE_WITH_RANDOM_32B

# ─── MinIO (object storage) ──────────────────────────────────────────────────
MINIO_ROOT_USER=translog_minio_admin
MINIO_ROOT_PASSWORD=REPLACE_WITH_RANDOM_32B

# ─── Vault (secrets metadata) ────────────────────────────────────────────────
# Généré par `vault operator init` lors du premier démarrage.
# SAUVEGARDE les 5 unseal keys dans un password manager — sans elles, les
# secrets Vault sont perdus définitivement.
VAULT_TOKEN=REPLACE_AFTER_VAULT_INIT

# ─── Sécurité applicative ────────────────────────────────────────────────────
# Clé bootstrap plateforme (provisioning initial super-admin)
PLATFORM_BOOTSTRAP_KEY=REPLACE_WITH_RANDOM_48B

# Clé partagée Caddy ↔ backend pour /internal/domain-check (on-demand TLS validation)
DOMAIN_CHECK_API_KEY=REPLACE_WITH_RANDOM_32B

# ─── Observability (optionnel, activer après MVP) ────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://gmp_otel-collector:80
# LOG_LEVEL=info

# ─── Providers tiers (ajoutés plus tard via Vault UI/CLI) ─────────────────────
# Stripe, Wave, MTN, SendGrid etc — stockés dans Vault sous tenants/:id/payment/
# Pas dans ce fichier.
