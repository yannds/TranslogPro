# ════════════════════════════════════════════════════════════════
# TransLog Pro Frontend — Variables d'environnement Vite
# ════════════════════════════════════════════════════════════════
# Copie ce fichier en `.env` ou `.env.local` pour override en dev :
#   cp frontend/.env.example frontend/.env.local
#
# Toutes les variables accessibles côté client DOIVENT être préfixées
# VITE_ (sinon Vite les ignore au build — convention Vite).
# ════════════════════════════════════════════════════════════════

# Domaine plateforme — mirroir backend PLATFORM_BASE_DOMAIN et
# scripts/dev.config.sh. Utilisé par frontend/lib/tenancy/host.ts pour
# résoudre window.location.host en slug tenant.
# Dev  : translog.test
# Prod : translogpro.com
VITE_PLATFORM_BASE_DOMAIN=translog.test
